# Copy to `.env` and adjust. Used by Docker Compose / local tooling.
# Do not commit `.env`.

# PostgreSQL (Compose service `db` in development)
DATABASE_HOST=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Rails (optional overrides)
# RAILS_MAX_THREADS=5

# Teller (optional; see docs/adr/0014 and 0020)
# TELLER_POST_DRAWER_VARIANCE_TO_GL=false

# Decrypt credentials (same value as `config/master.key` — keep secret)
# RAILS_MASTER_KEY=
