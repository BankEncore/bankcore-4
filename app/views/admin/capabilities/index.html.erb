<% content_for :title, "Capabilities - BankCORE" %>

<% capability_actions = capture do %>
  <%= link_to "Admin dashboard", admin_path, class: bc_button_class(:secondary) %>
  <%= link_to "New capability", new_admin_capability_path, class: bc_button_class(:primary) %>
<% end %>
<%= render "shared/internal/page_header",
  title: "Capabilities",
  subtitle: "Database capability catalog used by runtime authorization.",
  actions: capability_actions %>

<%= render "shared/internal/context_strip",
  operator: current_operator,
  surface: :admin,
  state_items: [
    ["Categories", @capabilities.keys.size],
    ["Capabilities", @capabilities.values.flatten.size]
  ] %>

<% @capabilities.each do |category, capabilities| %>
  <% capability_table = capture do %>
    <table class="min-w-full divide-y divide-slate-200 text-sm">
      <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
        <tr>
          <th class="px-5 py-3">Capability</th>
          <th class="px-5 py-3">Status</th>
          <th class="px-5 py-3 text-right">Roles</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% capabilities.each do |capability| %>
          <tr>
            <td class="px-5 py-4">
              <%= link_to capability.code, admin_capability_path(capability), class: "font-medium text-slate-950 underline" %>
              <div class="text-xs text-slate-500"><%= capability.name %></div>
            </td>
            <td class="px-5 py-4"><%= admin_status_badge(capability.active? ? "active" : "inactive") %></td>
            <td class="px-5 py-4 text-right"><%= capability.roles.size %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
  <%= render "shared/internal/data_table",
    title: category.to_s.humanize,
    content: capability_table,
    class: "mt-8" %>
<% end %>
