<section class="mt-6 rounded border border-slate-200 bg-white shadow-sm">
  <% if rows.any? %>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-200 text-sm">
        <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
          <tr>
            <th class="px-5 py-3">Product</th>
            <th class="px-5 py-3">Type</th>
            <th class="px-5 py-3">Status</th>
            <th class="px-5 py-3 text-right"><%= value_label %></th>
            <th class="px-5 py-3">Currency</th>
            <th class="px-5 py-3">Effective</th>
            <th class="px-5 py-3">Ended</th>
            <th class="px-5 py-3">Description</th>
            <% if local_assigns[:rule_kind].present? %>
              <th class="px-5 py-3">Controls</th>
            <% end %>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% rows.each do |row| %>
            <tr>
              <td class="px-5 py-4">
                <%= link_to admin_product_label(row.deposit_product), admin_deposit_product_path(row.deposit_product), class: "font-medium text-slate-950 underline" %>
              </td>
              <td class="px-5 py-4"><%= admin_rule_type(row) %></td>
              <td class="px-5 py-4"><%= admin_status_badge(row.status) %></td>
              <td class="px-5 py-4 text-right"><%= admin_rule_value(row) %></td>
              <td class="px-5 py-4"><%= row.currency %></td>
              <td class="px-5 py-4"><%= admin_date(row.effective_on) %></td>
              <td class="px-5 py-4"><%= admin_date(row.ended_on) %></td>
              <td class="px-5 py-4"><%= row.description.presence || "None" %></td>
              <% if local_assigns[:rule_kind].present? %>
                <td class="px-5 py-4">
                  <%= form_with url: admin_preview_end_date_rule_change_path(rule_kind, row.id), method: :post, scope: :rule_change, class: "flex items-end gap-2" do |form| %>
                    <div>
                      <%= form.label :ended_on, "End date", class: "sr-only" %>
                      <%= form.text_field :ended_on, placeholder: "YYYY-MM-DD", class: "w-32 rounded border border-slate-300 px-2 py-1" %>
                    </div>
                    <%= form.submit "Preview", class: "rounded border border-slate-300 px-3 py-1 font-medium text-slate-700" %>
                  <% end %>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="px-5 py-8 text-sm text-slate-600"><%= empty_message %></div>
  <% end %>
</section>
