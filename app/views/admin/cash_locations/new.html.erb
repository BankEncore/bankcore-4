<% content_for :title, "New Cash Location - BankCORE" %>
<% header_actions = capture do %>
  <%= link_to "All cash locations", admin_cash_locations_path, class: bc_button_class(:secondary) %>
<% end %>

<%= render "shared/internal/page_header",
  title: "New cash location",
  subtitle: "Create a vault, teller drawer, or internal transit location.",
  actions: header_actions %>

<%= render "shared/internal/context_strip",
  surface: :admin,
  state_items: [["Mode", "Create cash location"]] %>

<section class="mt-8">
  <%= render "form" %>
</section>
