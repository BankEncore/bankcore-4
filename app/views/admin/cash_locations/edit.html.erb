<% content_for :title, "Edit Cash Location - BankCORE" %>
<% header_actions = capture do %>
  <%= link_to "Cash location detail", admin_cash_location_path(@cash_location), class: bc_button_class(:secondary) %>
<% end %>

<%= render "shared/internal/page_header",
  title: "Edit cash location",
  subtitle: @cash_location.name,
  actions: header_actions %>

<%= render "shared/internal/context_strip",
  surface: :admin,
  operating_unit: @cash_location.operating_unit,
  operator: @cash_location.responsible_operator,
  state_items: [
    ["Mode", "Edit cash location"],
    ["Status", @cash_location.status.humanize]
  ] %>

<section class="mt-8">
  <%= render "form" %>
</section>
