<% content_for :title, "#{@deposit_product.product_code} Readiness - BankCORE" %>
<% header_actions = capture do %>
  <%= link_to "Product detail", admin_deposit_product_path(@deposit_product), class: bc_button_class(:secondary) %>
<% end %>
<% readiness_filter = capture do %>
  <%= form_with url: admin_deposit_product_readiness_path(@deposit_product), method: :get, class: "flex items-end gap-3" do |form| %>
    <div>
      <%= form.label :as_of, "As of", class: "block text-sm font-medium text-slate-700" %>
      <%= form.text_field :as_of, value: @as_of&.iso8601 || params[:as_of], placeholder: "YYYY-MM-DD", class: "mt-1 rounded border border-slate-300 px-3 py-2" %>
    </div>
    <%= form.submit "Review", class: bc_button_class(:primary) %>
  <% end %>
<% end %>

<%= render "shared/internal/page_header",
  title: "Product readiness",
  subtitle: admin_product_label(@deposit_product),
  actions: header_actions %>

<%= render "shared/internal/context_strip",
  surface: :admin,
  state_items: [["As of", @as_of&.iso8601 || params[:as_of].presence || "Current configuration"]] %>

<%= render "shared/internal/page_section",
  title: "Review window",
  description: "Check whether the product has the active configuration required by the shipped engines.",
  content: readiness_filter,
  class: "mt-6" %>

<% if @error_message.present? %>
  <section class="mt-6 <%= bc_status_banner_class(:warning) %>"><%= @error_message %></section>
<% else %>
  <section class="mt-8 grid gap-4 md:grid-cols-2">
    <% @checks.each do |check| %>
      <div class="<%= check[:ready] ? bc_panel_class(tone: :default).sub('border-[var(--bc-color-border)] bg-[var(--bc-color-surface)]', 'border-emerald-200 bg-emerald-50') : bc_panel_class(tone: :warning) %> p-5">
        <p class="text-sm font-medium <%= check[:ready] ? "text-emerald-800" : "text-amber-900" %>"><%= check[:label] %></p>
        <p class="mt-2 text-2xl font-semibold"><%= check[:ready] ? "Ready" : "Needs configuration" %></p>
      </div>
    <% end %>
  </section>
<% end %>
