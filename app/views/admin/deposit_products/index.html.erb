<% content_for :title, "Deposit Products - BankCORE" %>
<% header_actions = capture do %>
  <%= link_to "Admin dashboard", admin_path, class: bc_button_class(:secondary) %>
<% end %>

<%= render "shared/internal/page_header",
  title: "Deposit products",
  subtitle: "Read-only product catalog and configuration summary.",
  actions: header_actions %>

<%= render "shared/internal/context_strip",
  surface: :admin,
  state_items: [["Products", @deposit_products.size]] %>

<% product_table = if @deposit_products.any?
  capture do %>
      <table class="min-w-full divide-y divide-slate-200 text-sm">
        <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
          <tr>
            <th class="px-5 py-3">Product</th>
            <th class="px-5 py-3">Status</th>
            <th class="px-5 py-3">Currency</th>
            <th class="px-5 py-3 text-right">Fee rules</th>
            <th class="px-5 py-3 text-right">OD policies</th>
            <th class="px-5 py-3 text-right">Statement profiles</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @deposit_products.each do |product| %>
            <tr>
              <td class="px-5 py-4">
                <%= link_to product.product_code, admin_deposit_product_path(product), class: "font-medium text-slate-950 underline" %>
                <div class="text-xs text-slate-500"><%= product.name %></div>
              </td>
              <td class="px-5 py-4"><%= admin_status_badge(product.status) %></td>
              <td class="px-5 py-4"><%= product.currency %></td>
              <td class="px-5 py-4 text-right"><%= product.fee_rules_count %></td>
              <td class="px-5 py-4 text-right"><%= product.overdraft_policies_count %></td>
              <td class="px-5 py-4 text-right"><%= product.statement_profiles_count %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
  <% end
end %>

<%= render "shared/internal/data_table",
  title: "Product catalog",
  description: "Configured deposit products and counts of the rule families attached to each one.",
  empty: "No deposit products configured.",
  content: product_table,
  class: "mt-8" %>
