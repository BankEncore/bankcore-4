<% content_for :title, "#{@deposit_product.product_code} - BankCORE" %>
<% header_actions = capture do %>
  <%= link_to "All products", admin_deposit_products_path, class: bc_button_class(:secondary) %>
  <%= link_to "Readiness", admin_deposit_product_readiness_path(@deposit_product), class: bc_button_class(:primary) %>
<% end %>

<%= render "shared/internal/page_header",
  title: @deposit_product.product_code,
  subtitle: @deposit_product.name,
  actions: header_actions %>

<%= render "shared/internal/context_strip",
  surface: :admin,
  state_items: [
    ["Currency", @deposit_product.currency],
    ["Status", @deposit_product.status.humanize]
  ] %>

<section class="mt-8 grid gap-4 md:grid-cols-3">
  <div class="<%= bc_panel_class(tone: :default) %> p-5">
    <p class="text-sm font-medium text-slate-500">Status</p>
    <div class="mt-3"><%= admin_status_badge(@deposit_product.status) %></div>
  </div>
  <div class="<%= bc_panel_class(tone: :default) %> p-5">
    <p class="text-sm font-medium text-slate-500">Currency</p>
    <p class="mt-2 text-2xl font-semibold"><%= @deposit_product.currency %></p>
  </div>
  <div class="<%= bc_panel_class(tone: :default) %> p-5">
    <p class="text-sm font-medium text-slate-500">Created</p>
    <p class="mt-2 text-2xl font-semibold"><%= admin_date(@deposit_product.created_at.to_date) %></p>
  </div>
</section>

<section class="mt-8 grid gap-4 md:grid-cols-3">
  <div class="<%= bc_panel_class(tone: :default) %> p-5">
    <p class="text-sm font-medium text-slate-500">Open accounts</p>
    <p class="mt-2 text-2xl font-semibold"><%= @account_counts.fetch(Accounts::Models::DepositAccount::STATUS_OPEN, 0) %></p>
  </div>
  <div class="<%= bc_panel_class(tone: :default) %> p-5">
    <p class="text-sm font-medium text-slate-500">Closed accounts</p>
    <p class="mt-2 text-2xl font-semibold"><%= @account_counts.fetch(Accounts::Models::DepositAccount::STATUS_CLOSED, 0) %></p>
  </div>
  <div class="<%= bc_panel_class(tone: :default) %> p-5">
    <p class="text-sm font-medium text-slate-500">Configured rule families</p>
    <p class="mt-2 text-2xl font-semibold"><%= [@deposit_product.deposit_product_fee_rules.any?, @deposit_product.deposit_product_overdraft_policies.any?, @deposit_product.deposit_product_statement_profiles.any?].count(true) %> / 3</p>
  </div>
</section>

<%= render "rule_table",
  title: "Fee rules",
  rows: @deposit_product.deposit_product_fee_rules.order(:effective_on, :id),
  empty_message: "No fee rules configured for this product.",
  index_path: admin_deposit_product_fee_rules_path(deposit_product_id: @deposit_product.id) %>

<%= render "rule_table",
  title: "Overdraft policies",
  rows: @deposit_product.deposit_product_overdraft_policies.order(:effective_on, :id),
  empty_message: "No overdraft policies configured for this product.",
  index_path: admin_deposit_product_overdraft_policies_path(deposit_product_id: @deposit_product.id) %>

<%= render "rule_table",
  title: "Statement profiles",
  rows: @deposit_product.deposit_product_statement_profiles.order(:effective_on, :id),
  empty_message: "No statement profiles configured for this product.",
  index_path: admin_deposit_product_statement_profiles_path(deposit_product_id: @deposit_product.id) %>

<% recent_account_table = if @recent_accounts.any?
  capture do %>
      <table class="min-w-full divide-y divide-slate-200 text-sm">
        <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
          <tr>
            <th class="px-5 py-3">Account</th>
            <th class="px-5 py-3">Status</th>
            <th class="px-5 py-3">Currency</th>
              <th class="px-5 py-3">Created</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @recent_accounts.each do |account| %>
            <tr>
              <td class="px-5 py-4">
                <div class="font-medium text-slate-950"><%= account.account_number %></div>
                <div class="text-xs text-slate-500">#<%= account.id %></div>
              </td>
              <td class="px-5 py-4"><%= admin_status_badge(account.status) %></td>
              <td class="px-5 py-4"><%= account.currency %></td>
              <td class="px-5 py-4"><%= admin_date(account.created_at.to_date) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
  <% end
end %>

<%= render "shared/internal/data_table",
  title: "Recent accounts using this product",
  empty: "No accounts currently use this product.",
  content: recent_account_table,
  class: "mt-8" %>
