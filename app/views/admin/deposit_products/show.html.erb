<% content_for :title, "#{@deposit_product.product_code} - BankCORE" %>

<section class="flex flex-col justify-between gap-4 md:flex-row md:items-end">
  <div>
    <h1 class="text-3xl font-semibold"><%= @deposit_product.product_code %></h1>
    <p class="mt-2 text-slate-600"><%= @deposit_product.name %></p>
  </div>
  <%= link_to "All products", admin_deposit_products_path, class: "rounded border border-slate-300 px-4 py-2 font-medium text-slate-700" %>
</section>

<section class="mt-8 grid gap-4 md:grid-cols-3">
  <div class="rounded border border-slate-200 bg-white p-5 shadow-sm">
    <p class="text-sm font-medium text-slate-500">Status</p>
    <div class="mt-3"><%= admin_status_badge(@deposit_product.status) %></div>
  </div>
  <div class="rounded border border-slate-200 bg-white p-5 shadow-sm">
    <p class="text-sm font-medium text-slate-500">Currency</p>
    <p class="mt-2 text-2xl font-semibold"><%= @deposit_product.currency %></p>
  </div>
  <div class="rounded border border-slate-200 bg-white p-5 shadow-sm">
    <p class="text-sm font-medium text-slate-500">Created</p>
    <p class="mt-2 text-2xl font-semibold"><%= admin_date(@deposit_product.created_at.to_date) %></p>
  </div>
</section>

<%= render "rule_table",
  title: "Fee rules",
  rows: @deposit_product.deposit_product_fee_rules.order(:effective_on, :id),
  empty_message: "No fee rules configured for this product.",
  index_path: admin_deposit_product_fee_rules_path(deposit_product_id: @deposit_product.id) %>

<%= render "rule_table",
  title: "Overdraft policies",
  rows: @deposit_product.deposit_product_overdraft_policies.order(:effective_on, :id),
  empty_message: "No overdraft policies configured for this product.",
  index_path: admin_deposit_product_overdraft_policies_path(deposit_product_id: @deposit_product.id) %>

<%= render "rule_table",
  title: "Statement profiles",
  rows: @deposit_product.deposit_product_statement_profiles.order(:effective_on, :id),
  empty_message: "No statement profiles configured for this product.",
  index_path: admin_deposit_product_statement_profiles_path(deposit_product_id: @deposit_product.id) %>
