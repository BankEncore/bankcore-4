<% content_for :title, "New Operator - BankCORE" %>
<% header_actions = capture do %>
  <%= link_to "All operators", admin_operators_path, class: bc_button_class(:secondary) %>
<% end %>

<%= render "shared/internal/page_header",
  title: "New operator",
  subtitle: "Create an internal operator and optional first credential.",
  actions: header_actions %>

<%= render "shared/internal/context_strip",
  surface: :admin,
  state_items: [["Mode", "Create operator"]] %>

<section class="mt-8">
  <%= render "form" %>
</section>
