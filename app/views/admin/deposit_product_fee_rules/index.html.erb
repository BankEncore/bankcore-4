<% content_for :title, "Deposit Product Fee Rules - BankCORE" %>
<% header_actions = capture do %>
  <%= link_to "New fee rule", admin_new_rule_change_path("fee_rule", deposit_product_id: @deposit_product_id), class: bc_button_class(:primary) %>
<% end %>

<%= render "shared/internal/page_header",
  title: "Fee rules",
  subtitle: "Monthly maintenance fee configuration for deposit products.",
  actions: header_actions %>

<%= render "admin/shared/rule_filters", path: admin_deposit_product_fee_rules_path, as_of: @as_of %>
<%= render "admin/shared/rule_index_table",
  rows: @fee_rules,
  value_label: "Amount",
  rule_kind: "fee_rule",
  empty_message: "No fee rules matched these filters." %>
