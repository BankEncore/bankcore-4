<% content_for :title, "Preview #{admin_rule_kind_label(@rule_kind)} - BankCORE" %>

<section>
  <h1 class="text-3xl font-semibold">Preview <%= admin_rule_kind_label(@rule_kind).downcase %></h1>
  <p class="mt-2 text-slate-600">Confirm this effective-dated change before it is written.</p>
</section>

<%= render "summary", result: @result %>

<section class="mt-6 rounded border border-slate-200 bg-white p-5 shadow-sm">
  <h2 class="text-xl font-semibold">Confirmation</h2>
  <p class="mt-2 text-sm text-slate-600">Creating this row will end-date overlapping active rows shown above.</p>
  <%= form_with url: admin_rule_changes_path(@rule_kind), method: :post, scope: :rule_change, class: "mt-4" do |form| %>
    <% @rule_attrs.each do |key, value| %>
      <%= form.hidden_field key, value: value %>
    <% end %>
    <%= form.submit "Create #{admin_rule_kind_label(@rule_kind)}", class: "rounded bg-slate-900 px-4 py-2 font-medium text-white" %>
  <% end %>
</section>
