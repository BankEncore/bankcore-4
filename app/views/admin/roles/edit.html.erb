<% content_for :title, "Edit Role - BankCORE" %>
<% header_actions = capture do %>
  <%= link_to "Role detail", admin_role_path(@role), class: bc_button_class(:secondary) %>
<% end %>

<%= render "shared/internal/page_header",
  title: "Edit role",
  subtitle: @role.code,
  actions: header_actions %>

<%= render "shared/internal/context_strip",
  surface: :admin,
  state_items: [
    ["Mode", "Edit role"],
    ["Status", (@role.active? ? "Active" : "Inactive")]
  ] %>

<section class="mt-8">
  <%= render "form" %>
</section>
