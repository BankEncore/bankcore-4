<% content_for :title, "New Role - BankCORE" %>
<% header_actions = capture do %>
  <%= link_to "All roles", admin_roles_path, class: bc_button_class(:secondary) %>
<% end %>

<%= render "shared/internal/page_header",
  title: "New role",
  subtitle: "Create a custom role and initial capability mapping.",
  actions: header_actions %>

<%= render "shared/internal/context_strip",
  surface: :admin,
  state_items: [["Mode", "Create role"]] %>

<section class="mt-8">
  <%= render "form" %>
</section>
