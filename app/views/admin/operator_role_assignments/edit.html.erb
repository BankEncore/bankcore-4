<% content_for :title, "Edit Role Assignment - BankCORE" %>
<% header_actions = capture do %>
  <%= link_to "Operator detail", admin_operator_path(@operator), class: bc_button_class(:secondary) %>
<% end %>

<%= render "shared/internal/page_header",
  title: "Edit role assignment",
  subtitle: @operator.display_name,
  actions: header_actions %>

<%= render "shared/internal/context_strip",
  surface: :admin,
  operating_unit: @operator.default_operating_unit,
  operator: @operator,
  state_items: [
    ["Mode", "Edit role assignment"],
    ["Assignment status", (@assignment.active? ? "Active" : "Inactive")]
  ] %>

<section class="mt-8">
  <%= render "form" %>
</section>
