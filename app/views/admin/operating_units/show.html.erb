<% content_for :title, "#{@operating_unit.code} - BankCORE" %>

<% operating_unit_actions = capture do %>
  <%= link_to "All operating units", admin_operating_units_path, class: bc_button_class(:secondary) %>
  <%= link_to "Edit", edit_admin_operating_unit_path(@operating_unit), class: bc_button_class(:secondary) %>
<% end %>
<%= render "shared/internal/page_header",
  title: @operating_unit.code,
  subtitle: @operating_unit.name,
  actions: operating_unit_actions %>

<%= render "shared/internal/context_strip",
  operator: current_operator,
  surface: :admin,
  state_items: [
    ["Status", @operating_unit.status],
    ["Type", @operating_unit.unit_type.humanize],
    ["Time zone", @operating_unit.time_zone]
  ] %>

<section class="mt-8 grid gap-4 md:grid-cols-4">
  <div class="<%= bc_panel_class(tone: :default) %> p-5">
    <p class="text-sm font-medium text-slate-500">Status</p>
    <div class="mt-3"><%= admin_status_badge(@operating_unit.status) %></div>
  </div>
  <div class="<%= bc_panel_class(tone: :default) %> p-5">
    <p class="text-sm font-medium text-slate-500">Type</p>
    <p class="mt-2 text-2xl font-semibold"><%= @operating_unit.unit_type.humanize %></p>
  </div>
  <div class="<%= bc_panel_class(tone: :default) %> p-5">
    <p class="text-sm font-medium text-slate-500">Parent</p>
    <p class="mt-2 text-lg font-semibold"><%= admin_operating_unit_label(@operating_unit.parent_operating_unit) %></p>
  </div>
  <div class="<%= bc_panel_class(tone: :default) %> p-5">
    <p class="text-sm font-medium text-slate-500">Time zone</p>
    <p class="mt-2 text-lg font-semibold"><%= @operating_unit.time_zone %></p>
  </div>
</section>

<%= render "shared/internal/page_section",
  title: "Relationships and footprint",
  description: "Child units, cash locations, and scoped operators attached to this operating unit.",
  class: "mt-8",
  content: capture {
    content_tag(:div, class: "grid gap-4 md:grid-cols-2") do
      safe_join([
        content_tag(:div, class: bc_panel_class(tone: :default)) do
          safe_join([
            content_tag(:div, class: "border-b border-slate-200 px-5 py-4") { content_tag(:h2, "Child units", class: "text-xl font-semibold") },
            if @child_units.any?
              content_tag(:div, class: "divide-y divide-slate-100") do
                safe_join(@child_units.map do |unit|
                  content_tag(:div, class: "px-5 py-4 text-sm") do
                    safe_join([
                      link_to(unit.code, admin_operating_unit_path(unit), class: "font-medium underline"),
                      " ".html_safe,
                      content_tag(:span, unit.name, class: "text-slate-500")
                    ])
                  end
                end)
              end
            else
              content_tag(:div, "No child operating units.", class: "px-5 py-8 text-sm text-slate-600")
            end
          ])
        end,
        content_tag(:div, class: bc_panel_class(tone: :default)) do
          safe_join([
            content_tag(:div, class: "border-b border-slate-200 px-5 py-4") { content_tag(:h2, "Cash locations", class: "text-xl font-semibold") },
            if @cash_locations.any?
              content_tag(:div, class: "divide-y divide-slate-100") do
                safe_join(@cash_locations.map do |location|
                  content_tag(:div, class: "px-5 py-4 text-sm") do
                    safe_join([
                      link_to(admin_cash_location_label(location), admin_cash_location_path(location), class: "font-medium underline"),
                      " ".html_safe,
                      content_tag(:span, location.location_type.humanize, class: "text-slate-500")
                    ])
                  end
                end)
              end
            else
              content_tag(:div, "No cash locations in this operating unit.", class: "px-5 py-8 text-sm text-slate-600")
            end
          ])
        end,
        content_tag(:div, class: bc_panel_class(tone: :default)) do
          safe_join([
            content_tag(:div, class: "border-b border-slate-200 px-5 py-4") { content_tag(:h2, "Defaulting operators", class: "text-xl font-semibold") },
            if @defaulting_operators.any?
              content_tag(:div, class: "divide-y divide-slate-100") do
                safe_join(@defaulting_operators.map do |operator|
                  content_tag(:div, class: "px-5 py-4 text-sm") do
                    link_to(operator.display_name, admin_operator_path(operator), class: "font-medium underline")
                  end
                end)
              end
            else
              content_tag(:div, "No operators default to this unit.", class: "px-5 py-8 text-sm text-slate-600")
            end
          ])
        end,
        content_tag(:div, class: bc_panel_class(tone: :default)) do
          safe_join([
            content_tag(:div, class: "border-b border-slate-200 px-5 py-4") { content_tag(:h2, "Scoped role assignments", class: "text-xl font-semibold") },
            if @scoped_assignments.any?
              content_tag(:div, class: "divide-y divide-slate-100") do
                safe_join(@scoped_assignments.map do |assignment|
                  content_tag(:div, class: "px-5 py-4 text-sm") do
                    safe_join([
                      link_to(assignment.operator.display_name, admin_operator_path(assignment.operator), class: "font-medium underline"),
                      " ".html_safe,
                      content_tag(:span, assignment.role.code, class: "text-slate-500")
                    ])
                  end
                end)
              end
            else
              content_tag(:div, "No scoped role assignments for this unit.", class: "px-5 py-8 text-sm text-slate-600")
            end
          ])
        end
      ])
    end
  } %>

<% unless @operating_unit.status == Organization::Models::OperatingUnit::STATUS_CLOSED %>
  <%= render "shared/internal/status_banner",
    tone: :warning,
    title: "Close operating unit",
    body: capture {
      safe_join([
        content_tag(:p, "Closing is blocked while active child units or active cash locations remain.", class: "text-sm"),
        form_with(url: close_admin_operating_unit_path(@operating_unit), scope: :operating_unit, method: :post, local: true, class: "mt-4 flex flex-col gap-3 md:flex-row md:items-end") do |form|
          safe_join([
            content_tag(:div) do
              safe_join([
                form.label(:closed_on, class: "text-sm font-medium"),
                form.date_field(:closed_on, value: Date.current, class: "mt-1 rounded border border-amber-300 px-3 py-2")
              ])
            end,
            form.submit("Close operating unit", class: "inline-flex items-center justify-center rounded-md border border-amber-300 px-4 py-2 text-sm font-medium text-amber-950 hover:bg-amber-100")
          ])
        end
      ])
    } %>
<% end %>
