<% content_for :title, "Deposit Product Overdraft Policies - BankCORE" %>
<% header_actions = capture do %>
  <%= link_to "New overdraft policy", admin_new_rule_change_path("overdraft_policy", deposit_product_id: @deposit_product_id), class: bc_button_class(:primary) %>
<% end %>

<%= render "shared/internal/page_header",
  title: "Overdraft policies",
  subtitle: "Deny-NSF policy configuration for deposit products.",
  actions: header_actions %>

<%= render "admin/shared/rule_filters", path: admin_deposit_product_overdraft_policies_path, as_of: @as_of %>
<%= render "admin/shared/rule_index_table",
  rows: @overdraft_policies,
  value_label: "NSF fee",
  rule_kind: "overdraft_policy",
  empty_message: "No overdraft policies matched these filters." %>
