<% content_for :title, "Deposit Product Statement Profiles - BankCORE" %>
<% header_actions = capture do %>
  <%= link_to "New statement profile", admin_new_rule_change_path("statement_profile", deposit_product_id: @deposit_product_id), class: bc_button_class(:primary) %>
<% end %>

<%= render "shared/internal/page_header",
  title: "Statement profiles",
  subtitle: "Statement cycle profile configuration for deposit products.",
  actions: header_actions %>

<%= render "admin/shared/rule_filters", path: admin_deposit_product_statement_profiles_path, as_of: @as_of %>
<%= render "admin/shared/rule_index_table",
  rows: @statement_profiles,
  value_label: "Cycle",
  rule_kind: "statement_profile",
  empty_message: "No statement profiles matched these filters." %>
