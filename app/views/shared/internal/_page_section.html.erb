<section class="<%= [local_assigns[:class], bc_panel_class(tone: local_assigns[:tone] || :default)].compact.join(" ") %>">
  <% if local_assigns[:title].present? || local_assigns[:description].present? || local_assigns[:actions].present? %>
    <div class="border-b border-[var(--bc-color-border)] px-5 py-4">
      <div class="flex flex-col justify-between gap-3 md:flex-row md:items-start">
        <div>
          <% if local_assigns[:title].present? %>
            <h2 class="text-xl font-semibold"><%= title %></h2>
          <% end %>
          <% if local_assigns[:description].present? %>
            <p class="mt-1 text-sm text-slate-600"><%= description %></p>
          <% end %>
        </div>
        <% if local_assigns[:actions].present? %>
          <div class="flex flex-wrap gap-2 text-sm">
            <%= actions %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="p-5">
    <%= content %>
  </div>
</section>
