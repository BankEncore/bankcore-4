<% content_for :title, "Ops Event Search - BankCORE" %>
<%= render "shared/internal/page_header",
  title: "Operational event search",
  subtitle: "Search event history across the current or historical business dates." %>

<%= render "shared/internal/filter_bar",
  title: "Filters",
  description: "Search by date, support keys, event type, channel, actor, product, and operating unit.",
  class: "mt-6" do %>
  <%= form_with url: ops_operational_events_path, method: :get, class: "grid gap-4 md:grid-cols-4" do |form| %>
    <% {
      business_date: "Business date",
      business_date_from: "Date from",
      business_date_to: "Date to",
      status: "Status",
      event_type: "Event type",
      operating_unit_id: "Operating unit id",
      channel: "Channel",
      source_account_id: "Source account id",
      destination_account_id: "Destination account id",
      actor_id: "Actor id",
      reference_id: "Reference id",
      idempotency_key: "Idempotency key",
      reversal_of_event_id: "Reversal of event id",
      deposit_product_id: "Product id",
      product_code: "Product code",
      limit: "Limit"
    }.each do |field, label| %>
      <div>
        <%= form.label field, label, class: "block text-sm font-medium text-slate-700" %>
        <%= form.text_field field, value: params[field], class: "mt-1 w-full rounded border border-slate-300 px-3 py-2" %>
      </div>
    <% end %>

    <div class="md:col-span-4">
      <p class="text-sm font-medium text-slate-700">Event types (OR) — optional multi-select for drills</p>
      <% preset_types = Array.wrap(params[:event_type_in]).reject(&:blank?) %>
      <%= form.select :event_type_in,
            options_for_select(
              [
                [ "override.requested", "override.requested" ],
                [ "override.approved", "override.approved" ],
                [ "posting.reversal", "posting.reversal" ],
                [ "overdraft.nsf_denied", "overdraft.nsf_denied" ]
              ],
              preset_types
            ),
            {},
            multiple: true,
            name: "event_type_in[]",
            class: "mt-1 min-h-[7rem] w-full max-w-xl rounded border border-slate-300 px-3 py-2",
            size: 6 %>
      <p class="mt-1 text-xs text-slate-500">Hold Ctrl/Cmd to select multiple. Leave empty when using single Event type above.</p>
    </div>

    <div class="flex items-end gap-3 md:col-span-4">
      <%= form.submit "Search", class: "rounded bg-slate-900 px-4 py-2 font-medium text-white" %>
      <%= link_to "Clear filters", ops_operational_events_path, class: "rounded border border-slate-300 px-4 py-2 font-medium text-slate-700" %>
    </div>
  <% end %>
<% end %>

<% if @error_message.present? %>
  <section class="mt-6 rounded border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900">
    <%= @error_message %>
  </section>
<% elsif @event_search.present? %>
  <% envelope = @event_search[:envelope] %>
  <%= render "shared/internal/context_strip",
    business_date: envelope[:current_business_on],
    reviewed_business_date: (params[:business_date].presence || envelope[:business_date_from]),
    operating_unit: @scoped_operating_unit,
    operator: current_operator,
    state_items: [
      ["Date range", "#{envelope[:business_date_from].iso8601} to #{envelope[:business_date_to].iso8601}"],
      ["Posting day closed", (envelope[:posting_day_closed] ? "Yes" : "No")],
      ["Results on this page", "#{@event_search[:rows].size}#{@event_search[:has_more] ? ' (more on next page)' : ''}"]
    ] %>

  <section class="<%= bc_panel_class(tone: :muted) %> mt-6 p-5 text-sm text-slate-600">
    Showing <%= envelope[:business_date_from].iso8601 %> to <%= envelope[:business_date_to].iso8601 %>.
    Current business date is <%= envelope[:current_business_on].iso8601 %>.
    Posting day closed: <%= envelope[:posting_day_closed] ? "yes" : "no" %>.
    <% if @scoped_operating_unit.present? %>
      Operating unit filter: <strong><%= @scoped_operating_unit.code %></strong> (id <%= @scoped_operating_unit.id %>).
    <% end %>
    <% if params[:event_type_in].present? %>
      Event types (OR): <strong><%= Array.wrap(params[:event_type_in]).reject(&:blank?).join(", ") %></strong>.
    <% elsif params[:event_type].present? %>
      Event type: <strong><%= params[:event_type] %></strong>.
    <% end %>
    <% if params[:status].present? %>
      Status: <strong><%= params[:status] %></strong>.
    <% end %>
    <% if params[:channel].present? %>
      Channel: <strong><%= params[:channel] %></strong>.
    <% end %>
  </section>

  <% if @event_search[:rows].any? %>
    <%= render "shared/internal/data_table",
      title: "Operational events",
      description: "Filtered event-backed record set for the selected business-date and support criteria.",
      class: "mt-6" do %>
        <table class="min-w-full divide-y divide-slate-200 text-sm">
          <thead class="sticky top-0 z-10 bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
            <tr>
              <th class="px-5 py-3">Event id</th>
              <th class="px-5 py-3">Created</th>
              <th class="px-5 py-3">Status</th>
              <th class="px-5 py-3">Event type</th>
              <th class="px-5 py-3">Business date</th>
              <th class="px-5 py-3">Channel</th>
              <th class="px-5 py-3 text-right">Amount</th>
              <th class="px-5 py-3">Source</th>
              <th class="px-5 py-3">Destination</th>
              <th class="px-5 py-3">Actor/session</th>
              <th class="px-5 py-3">Support keys</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @event_search[:rows].each do |event| %>
              <tr class="focus-within:bg-slate-50 hover:bg-slate-50">
                <td class="px-5 py-4">
                  <%= link_to "##{event.id}", ops_operational_event_path(event), class: "font-semibold text-slate-950 underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-slate-500" %>
                  <div class="text-xs text-slate-500">Primary action: view details</div>
                </td>
                <td class="px-5 py-4"><%= ops_time(event.created_at) %></td>
                <td class="px-5 py-4"><%= ops_status_badge(event.status) %></td>
                <td class="px-5 py-4"><%= ops_event_type_badge(event.event_type) %></td>
                <td class="px-5 py-4"><%= event.business_date.iso8601 %></td>
                <td class="px-5 py-4"><%= event.channel %></td>
                <td class="px-5 py-4 text-right"><%= ops_event_amount(event) %></td>
                <td class="px-5 py-4"><%= ops_account_label(event.source_account) %></td>
                <td class="px-5 py-4"><%= ops_account_label(event.destination_account) %></td>
                <td class="px-5 py-4">
                  <div>Actor <%= event.actor_id || "none" %></div>
                  <div class="text-xs text-slate-500">Session <%= event.teller_session_id || "none" %></div>
                </td>
                <td class="px-5 py-4 text-xs text-slate-600">
                  <div>Reference: <%= event.reference_id.presence || "none" %></div>
                  <div>Idempotency: <%= event.idempotency_key %></div>
                  <div>Reversal of: <%= event.reversal_of_event_id || "none" %></div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
    <% end %>
  <% else %>
    <% empty_state = capture do %>
        <p>No operational events matched these filters.</p>
        <div class="mt-4 flex flex-wrap gap-2">
          <%= link_to "Clear filters", ops_operational_events_path, class: "rounded border border-slate-300 bg-white px-3 py-1.5 font-medium text-slate-700" %>
          <%= link_to "Try broader date range", ops_operational_events_path(request.query_parameters.merge(business_date: nil, business_date_from: nil, business_date_to: nil, limit: 100)), class: "rounded border border-slate-300 bg-white px-3 py-1.5 font-medium text-slate-700" %>
        </div>
    <% end %>
    <%= render "shared/internal/data_table",
      title: "Operational events",
      description: "Filtered event-backed record set for the selected business-date and support criteria.",
      empty: empty_state,
      class: "mt-6" %>
  <% end %>

  <% if @event_search[:has_more] %>
    <div class="mt-6">
      <%= link_to "Next page",
        ops_operational_events_path(request.query_parameters.except("after_id").merge(after_id: @event_search[:next_after_id])),
        class: "rounded bg-slate-900 px-4 py-2 font-medium text-white" %>
    </div>
  <% end %>
<% end %>
