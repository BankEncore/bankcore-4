<% content_for :title, "Cash Reconciliation - BankCORE" %>

<% reconciliation_actions = capture do %>
  <%= link_to "Cash approvals", ops_cash_path, class: bc_button_class(:secondary) %>
<% end %>
<%= render "shared/internal/page_header",
  title: "Cash reconciliation",
  subtitle: "Compare Cash-domain custody balances against GL 1110 evidence.",
  actions: reconciliation_actions %>

<% difference = @summary.fetch(:difference_minor_units).to_i %>
<% reviewed_business_date = @summary[:business_date] %>
<% reviewed_business_date_label = reviewed_business_date.respond_to?(:iso8601) ? reviewed_business_date.iso8601 : reviewed_business_date.to_s %>
<%= render "shared/internal/context_strip",
  business_date: (reviewed_business_date.presence || current_business_date),
  operating_unit: current_operating_unit,
  operator: current_operator,
  state_items: [
    ["Reconciliation scope", (reviewed_business_date.present? ? "business-date review" : "current subledger state")],
    ["Difference", ops_money(difference, signed: true)]
  ] %>

<% if reviewed_business_date.present? %>
  <%= render "shared/internal/status_banner",
    tone: :info,
    title: "Reviewed business date",
    body: "GL 1110 is filtered to #{reviewed_business_date_label}; cash subledger remains current custody state for the selected operating unit." %>
<% end %>

<section class="mt-8 grid gap-4 md:grid-cols-3">
  <div class="<%= bc_panel_class(tone: :default) %> p-5">
    <p class="text-sm font-medium text-slate-500">Cash subledger</p>
    <p class="mt-2 text-2xl font-semibold"><%= number_to_currency(@summary.fetch(:cash_subledger_amount_minor_units) / 100.0) %></p>
  </div>
  <div class="<%= bc_panel_class(tone: :default) %> p-5">
    <p class="text-sm font-medium text-slate-500">GL 1110</p>
    <p class="mt-2 text-2xl font-semibold"><%= number_to_currency(@summary.fetch(:gl_1110_amount_minor_units) / 100.0) %></p>
  </div>
  <div class="<%= bc_panel_class(tone: :default) %> p-5">
    <p class="text-sm font-medium text-slate-500">Difference</p>
    <p class="mt-2 text-2xl font-semibold"><%= number_to_currency(difference / 100.0) %></p>
  </div>
</section>

<% reconciliation_explanation = capture do %>
  <dl class="grid gap-4 text-sm md:grid-cols-2">
    <div>
      <dt class="font-medium text-slate-500">Cash subledger definition</dt>
      <dd>Sum of current cash balances for active locations in the selected operating unit.</dd>
    </div>
    <div>
      <dt class="font-medium text-slate-500">GL definition</dt>
      <dd>Net debit/credit balance for GL account 1110, optionally filtered to the reviewed business date.</dd>
    </div>
    <div>
      <dt class="font-medium text-slate-500">Difference calculation</dt>
      <dd>Cash subledger minus GL 1110. Non-zero differences need custody or posting follow-up.</dd>
    </div>
    <div>
      <dt class="font-medium text-slate-500">Follow-up path</dt>
      <dd>Use Cash approvals for pending movements and variances, then compare again after approvals post.</dd>
    </div>
  </dl>
<% end %>
<%= render "shared/internal/page_section",
  title: "Reconciliation method",
  description: "What each number represents and how to investigate a non-zero difference.",
  content: reconciliation_explanation,
  class: "mt-8" %>
