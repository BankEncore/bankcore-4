<% content_for :title, "Balance Projections - BankCORE" %>

<% projection_actions = capture do %>
  <%= link_to "Bulk repair", ops_balance_projection_bulk_repair_path, class: bc_button_class(:secondary) %>
<% end %>
<%= render "shared/internal/page_header",
  title: "Balance projection health",
  subtitle: "Read projection drift, rebuild evidence, and daily snapshot health before operational repair.",
  actions: projection_actions %>

<%= render "shared/internal/context_strip",
  business_date: current_business_date,
  operator: current_operator,
  state_items: [
    ["Stale projections", @health.stale_projection_count],
    ["Pending rebuilds", @health.pending_rebuild_request_count],
    ["Latest snapshot date", @health.latest_snapshot_date&.iso8601 || "None"]
  ] %>

<section class="mt-8 grid gap-4 md:grid-cols-3">
  <%= render "ops/eod/readiness_card", label: "Stale projections", value: @health.stale_projection_count, state: @health.stale_projection_count.zero? %>
  <%= render "ops/eod/readiness_card", label: "Version mismatches", value: @health.projection_version_mismatch_count, state: @health.projection_version_mismatch_count.zero? %>
  <%= render "ops/eod/readiness_card", label: "Pending rebuilds", value: @health.pending_rebuild_request_count, state: @health.pending_rebuild_request_count.zero? %>
  <%= render "ops/eod/readiness_card", label: "Stale daily snapshots", value: @health.stale_daily_snapshot_count, state: @health.stale_daily_snapshot_count.zero? %>
  <%= render "ops/eod/readiness_card", label: "Latest snapshot date", value: @health.latest_snapshot_date&.iso8601 || "None", state: @health.latest_snapshot_date.present? %>
  <%= render "ops/eod/readiness_card", label: "Latest snapshot rows", value: @health.latest_snapshot_count, state: true %>
</section>

<%= render "shared/internal/filter_bar",
  title: "Account lookup",
  description: "Search by deposit account id or account number to inspect one projection.",
  class: "mt-8",
  content: capture {
    form_with url: ops_balance_projections_path, method: :get, class: "flex gap-3" do |form|
      safe_join([
        form.text_field(:account, value: params[:account], placeholder: "Account id or number", class: "w-full rounded border border-slate-300 px-3 py-2"),
        form.submit("Lookup", class: bc_button_class(:primary))
      ])
    end
  } %>

<% if @account_error.present? %>
  <%= render "shared/internal/status_banner",
    tone: :warning,
    title: "Lookup issue",
    body: @account_error %>
<% elsif @account.present? %>
  <%= render "shared/internal/page_section",
    title: "Account #{@account.account_number}",
    description: "Projection and drift evidence for account ##{@account.id}.",
    class: "mt-8",
    content: capture {
      safe_join([
        content_tag(:div, class: "grid gap-4 md:grid-cols-3") do
          safe_join([
            content_tag(:div, class: "rounded border border-slate-200 p-4") do
              safe_join([
                content_tag(:div, "Ledger", class: "text-sm text-slate-500"),
                content_tag(:div, ops_money(@projection&.ledger_balance_minor_units || 0, signed: true), class: "mt-1 text-2xl font-semibold")
              ])
            end,
            content_tag(:div, class: "rounded border border-slate-200 p-4") do
              safe_join([
                content_tag(:div, "Available", class: "text-sm text-slate-500"),
                content_tag(:div, ops_money(@projection&.available_balance_minor_units || 0, signed: true), class: "mt-1 text-2xl font-semibold")
              ])
            end,
            content_tag(:div, class: "rounded border border-slate-200 p-4") do
              safe_join([
                content_tag(:div, "Drift status", class: "text-sm text-slate-500"),
                content_tag(:div, ops_status_badge(@drift.drifted ? "drifted" : "current"), class: "mt-2")
              ])
            end
          ])
        end,
        content_tag(:div, class: "mt-6 border-t border-slate-200 pt-5") do
          safe_join([
            content_tag(:h3, "Single-account controls", class: "font-semibold"),
            content_tag(:p, "Ops reconciliation capability is required. Actions affect only this account.", class: "mt-1 text-sm text-slate-600"),
            content_tag(:div, class: "mt-4 flex flex-wrap gap-3") do
              safe_join([
                button_to("Mark stale", ops_mark_stale_balance_projection_path(@account), method: :post, class: "inline-flex items-center justify-center rounded-md border border-amber-300 bg-amber-50 px-4 py-2 text-sm font-medium text-amber-900 hover:bg-amber-100"),
                button_to("Rebuild projection", ops_rebuild_balance_projection_path(@account), method: :post, class: bc_button_class(:primary))
              ])
            end
          ])
        end,
        content_tag(:div, class: "mt-8 grid gap-6 lg:grid-cols-2") do
          safe_join([
            content_tag(:div, class: bc_panel_class(tone: :default)) do
              safe_join([
                content_tag(:div, class: "border-b border-slate-200 px-5 py-4") do
                  content_tag(:h3, "Rebuild evidence", class: "font-semibold")
                end,
                render("rebuild_requests", rebuild_requests: @rebuild_requests)
              ])
            end,
            content_tag(:div, class: bc_panel_class(tone: :default)) do
              safe_join([
                content_tag(:div, class: "border-b border-slate-200 px-5 py-4") do
                  content_tag(:h3, "Daily snapshots", class: "font-semibold")
                end,
                render("daily_snapshots", daily_snapshots: @daily_snapshots)
              ])
            end
          ])
        end
      ])
    } %>
<% end %>

<%= render "shared/internal/page_section",
  title: "Recent rebuild evidence",
  class: "mt-8",
  content: render("rebuild_requests", rebuild_requests: @health.recent_rebuild_requests) %>
