<% content_for :title, "Teller Variances - BankCORE" %>

<% teller_variance_actions = capture do %>
  <%= link_to "Teller sessions", ops_teller_sessions_path, class: bc_button_class(:secondary) %>
<% end %>
<%= render "shared/internal/page_header",
  title: "Teller variances",
  subtitle: "Pending supervisor teller-session variance approvals.",
  actions: teller_variance_actions %>

<%= render "shared/internal/context_strip",
  business_date: current_business_date,
  operator: current_operator,
  state_items: [
    ["Pending approvals", @sessions.size],
    ["Scope", "teller session close variances"]
  ] %>

<% teller_variance_table = capture do %>
  <% if @sessions.any? %>
    <table class="min-w-full divide-y divide-slate-200 text-sm">
      <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
        <tr>
          <th class="px-5 py-3">Session</th>
          <th class="px-5 py-3">Drawer</th>
          <th class="px-5 py-3">Opened</th>
          <th class="px-5 py-3 text-right">Expected</th>
          <th class="px-5 py-3 text-right">Actual</th>
          <th class="px-5 py-3 text-right">Variance</th>
          <th class="px-5 py-3">Action</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @sessions.each do |session| %>
          <tr>
            <td class="px-5 py-4 font-medium text-slate-950">#<%= session.id %></td>
            <td class="px-5 py-4"><%= session.drawer_code %></td>
            <td class="px-5 py-4"><%= ops_time(session.opened_at) %></td>
            <td class="px-5 py-4 text-right"><%= ops_money(session.expected_cash_minor_units) %></td>
            <td class="px-5 py-4 text-right"><%= ops_money(session.actual_cash_minor_units) %></td>
            <td class="px-5 py-4 text-right"><%= ops_money(session.variance_minor_units, signed: true) %></td>
            <td class="px-5 py-4">
              <%= button_to "Approve", approve_ops_teller_variance_path(session), method: :post, class: bc_button_class(:primary) %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
<% end %>
<%= render "shared/internal/data_table",
  title: "Pending supervisor approvals",
  description: "Closed sessions whose drawer variance exceeded the configured threshold.",
  content: teller_variance_table,
  empty: "No teller variances are pending approval.",
  class: "mt-8" %>
