<% content_for :title, "ACH Receipt Ingestion - BankCORE" %>

<section>
  <h1 class="text-3xl font-semibold">ACH receipt ingestion</h1>
  <p class="mt-2 text-slate-600">
    Upload or paste a structured ACH credit receipt JSON file. Full NACHA parsing is deferred; this form expects the Phase 4.7 structured input shape.
  </p>
</section>

<% if @error_message.present? %>
  <section class="mt-6 rounded border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900">
    <%= @error_message %>
  </section>
<% end %>

<section class="mt-6 rounded border border-slate-200 bg-white p-5 shadow-sm">
  <%= form_with url: ops_ach_receipt_ingestions_path, method: :post, multipart: true, class: "grid gap-5" do |form| %>
    <div>
      <%= form.label :receipt_file, "Structured JSON file", class: "block text-sm font-medium text-slate-700" %>
      <%= form.file_field :receipt_file, name: "ach_receipt_ingestion[receipt_file]", accept: "application/json,.json", class: "mt-1 block w-full text-sm text-slate-700 file:mr-4 file:rounded file:border-0 file:bg-slate-900 file:px-4 file:py-2 file:text-sm file:font-medium file:text-white" %>
      <p class="mt-1 text-xs text-slate-500">If a file is selected, it is used instead of the pasted JSON below.</p>
    </div>

    <div>
      <%= form.label :structured_input, "Structured JSON", class: "block text-sm font-medium text-slate-700" %>
      <%= form.text_area :structured_input,
        name: "ach_receipt_ingestion[structured_input]",
        value: @structured_input,
        rows: 16,
        spellcheck: false,
        class: "mt-1 w-full rounded border border-slate-300 px-3 py-2 font-mono text-sm" %>
    </div>

    <div class="max-w-xs">
      <%= form.label :business_date, "Business date override", class: "block text-sm font-medium text-slate-700" %>
      <%= form.text_field :business_date,
        name: "ach_receipt_ingestion[business_date]",
        value: @business_date.respond_to?(:iso8601) ? @business_date.iso8601 : @business_date,
        placeholder: "YYYY-MM-DD",
        class: "mt-1 w-full rounded border border-slate-300 px-3 py-2" %>
      <p class="mt-1 text-xs text-slate-500">Must equal the current open business date when supplied.</p>
    </div>

    <div class="rounded border border-slate-200 bg-slate-50 p-4 text-sm text-slate-600">
      Required item fields: <code>item_id</code>, <code>account_number</code>, <code>amount_minor_units</code>, and <code>currency</code>.
      Account numbers are treated as strings so leading zeroes are preserved.
    </div>

    <div class="flex flex-wrap gap-3">
      <%= button_tag "Preview", name: "mode", value: "preview", class: "rounded border border-slate-300 px-4 py-2 font-medium text-slate-700" %>
      <%= button_tag "Ingest and post", name: "mode", value: "ingest", class: "rounded bg-slate-900 px-4 py-2 font-medium text-white" %>
    </div>
  <% end %>
</section>
