<% content_for :title, "Ops Teller Sessions - BankCORE" %>

<% teller_session_actions = capture do %>
  <%= link_to "Close package", ops_close_package_path, class: bc_button_class(:secondary) %>
<% end %>
<%= render "shared/internal/page_header",
  title: "Teller sessions",
  subtitle: "Open and pending-supervisor drawer sessions across the institution.",
  actions: teller_session_actions %>

<%= render "shared/internal/context_strip",
  business_date: current_business_date,
  operator: current_operator,
  state_items: [
    ["Included statuses", "open, pending_supervisor"],
    ["Sessions in queue", @sessions.size]
  ] %>

<% teller_session_table = capture do %>
  <% if @sessions.any? %>
    <table class="min-w-full divide-y divide-slate-200 text-sm">
      <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
        <tr>
          <th class="px-5 py-3">Session</th>
          <th class="px-5 py-3">Status</th>
          <th class="px-5 py-3">Drawer</th>
          <th class="px-5 py-3">Operating unit</th>
          <th class="px-5 py-3">Cash location</th>
          <th class="px-5 py-3 text-right">Variance</th>
          <th class="px-5 py-3">Opened</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @sessions.each do |session| %>
          <tr class="hover:bg-slate-50">
            <td class="px-5 py-4">
              <%= link_to "##{session.id}", ops_teller_session_path(session), class: "font-semibold text-slate-950 underline" %>
            </td>
            <td class="px-5 py-4"><%= ops_status_badge(session.status) %></td>
            <td class="px-5 py-4"><%= session.drawer_code.presence || "Default drawer" %></td>
            <td class="px-5 py-4"><%= session.operating_unit&.code %> — <%= session.operating_unit&.name %></td>
            <td class="px-5 py-4"><%= session.cash_location&.name || "None" %></td>
            <td class="px-5 py-4 text-right"><%= ops_money(session.variance_minor_units, signed: true) %></td>
            <td class="px-5 py-4"><%= ops_time(session.opened_at) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
<% end %>
<%= render "shared/internal/data_table",
  title: "Session queue",
  description: "Active drawers and sessions waiting for supervisor variance approval.",
  content: teller_session_table,
  empty: "No open or pending-supervisor sessions.",
  class: "mt-8" %>
