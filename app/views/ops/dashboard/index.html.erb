<% content_for :title, "Ops Workspace - BankCORE" %>

<section>
  <h1 class="text-3xl font-semibold">Ops workspace</h1>
  <p class="mt-2 text-slate-600">
    Review EOD readiness, trial balance activity, and operational event history.
  </p>
</section>

<section class="mt-8 grid gap-4 md:grid-cols-2">
  <%= link_to ops_eod_path, class: "rounded border border-slate-200 bg-white p-5 shadow-sm hover:border-slate-400" do %>
    <h2 class="font-semibold">EOD readiness</h2>
    <p class="mt-2 text-sm text-slate-600">Review close readiness and activity trial balance for a business date.</p>
  <% end %>

  <%= link_to ops_operational_events_path, class: "rounded border border-slate-200 bg-white p-5 shadow-sm hover:border-slate-400" do %>
    <h2 class="font-semibold">Operational events</h2>
    <p class="mt-2 text-sm text-slate-600">Search posted and pending events with account and posting context.</p>
  <% end %>
</section>
