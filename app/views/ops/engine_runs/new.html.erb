<% content_for :title, "#{ops_engine_label(@engine)} Preview - BankCORE" %>

<%= render "shared/internal/page_header",
  title: ops_engine_label(@engine),
  subtitle: "Preview eligible work before executing this system engine.",
  actions: capture {
    link_to "Engine runs", ops_engine_runs_path, class: bc_button_class(:secondary)
  } %>

<%= render "shared/internal/context_strip",
  business_date: @business_date,
  operator: current_operator,
  state_items: [
    ["Engine", ops_engine_label(@engine)],
    ["Preview mode", "read-only"]
  ] %>

<%= render "shared/internal/filter_bar",
  title: "Preview parameters",
  description: "Set the business date and optional product/account scope before previewing the engine run.",
  class: "mt-6",
  content: capture {
    form_with url: ops_new_engine_run_path(@engine), method: :get, class: "grid gap-4 md:grid-cols-4" do |form|
      safe_join([
        content_tag(:div) do
          safe_join([
            form.label(:business_date, "Business date", class: "block text-sm font-medium text-slate-700"),
            form.text_field(:business_date, value: @business_date&.iso8601 || params[:business_date], placeholder: "YYYY-MM-DD", class: "mt-1 w-full rounded border border-slate-300 px-3 py-2")
          ])
        end,
        content_tag(:div) do
          safe_join([
            form.label(:deposit_product_id, "Product id", class: "block text-sm font-medium text-slate-700"),
            form.text_field(:deposit_product_id, value: @deposit_product_id, class: "mt-1 w-full rounded border border-slate-300 px-3 py-2")
          ])
        end,
        content_tag(:div) do
          safe_join([
            form.label(:account_ids, "Account ids", class: "block text-sm font-medium text-slate-700"),
            form.text_field(:account_ids, value: params[:account_ids], placeholder: "1, 2, 3", class: "mt-1 w-full rounded border border-slate-300 px-3 py-2")
          ])
        end,
        content_tag(:div, class: "flex items-end") do
          form.submit("Preview", class: bc_button_class(:primary))
        end
      ])
    end
  } %>

<% if @error_message.present? %>
  <%= render "shared/internal/status_banner",
    tone: :warning,
    title: "Preview issue",
    body: @error_message %>
<% elsif @result.present? %>
  <%= render "result_summary", result: @result, preview: true %>

  <%= render "shared/internal/page_section",
    title: "Confirmation",
    description: "Execute this run after reviewing the preview summary and sample outcomes.",
    class: "mt-6",
    content: capture {
      safe_join([
        content_tag(:p, "Execute this run for #{@business_date.iso8601}. The engine remains idempotent for previously processed rows.", class: "text-sm text-slate-600"),
        form_with(url: ops_engine_run_path(@engine), method: :post, class: "mt-4") do |form|
          safe_join([
            form.hidden_field(:business_date, value: @business_date.iso8601),
            form.hidden_field(:deposit_product_id, value: @deposit_product_id),
            form.hidden_field(:account_ids, value: params[:account_ids]),
            form.submit("Execute #{ops_engine_label(@engine)}", class: bc_button_class(:primary))
          ])
        end
      ])
    } %>
<% end %>
