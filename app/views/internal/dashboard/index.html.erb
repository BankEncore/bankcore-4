<% content_for :title, "Internal Dashboard - BankCORE" %>

<section>
  <h1 class="text-3xl font-semibold">Internal dashboard</h1>
  <p class="mt-2 text-slate-600">
    Signed in as <%= current_operator.display_name.presence || current_operator.role.titleize %>
    (<%= current_operator.role %>).
  </p>
</section>

<section class="mt-8 grid gap-4 md:grid-cols-3">
  <% if branch_access? %>
    <%= link_to branch_path, class: "rounded border border-slate-200 bg-white p-5 shadow-sm hover:border-slate-400" do %>
      <h2 class="font-semibold">Branch</h2>
      <p class="mt-2 text-sm text-slate-600">Branch-local teller and session workflows.</p>
    <% end %>
  <% end %>

  <% if ops_access? %>
    <%= link_to ops_path, class: "rounded border border-slate-200 bg-white p-5 shadow-sm hover:border-slate-400" do %>
      <h2 class="font-semibold">Ops</h2>
      <p class="mt-2 text-sm text-slate-600">EOD, trial balance, and operational event review.</p>
    <% end %>
  <% end %>

  <% if admin_access? %>
    <%= link_to admin_path, class: "rounded border border-slate-200 bg-white p-5 shadow-sm hover:border-slate-400" do %>
      <h2 class="font-semibold">Admin</h2>
      <p class="mt-2 text-sm text-slate-600">Product and internal configuration surfaces.</p>
    <% end %>
  <% end %>
</section>
