<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "BankCORE Internal" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-slate-100 text-slate-950">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded focus:bg-slate-900 focus:px-4 focus:py-2 focus:text-white">Skip to main content</a>
    <header class="border-b border-slate-200 bg-white">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <div>
          <%= link_to "BankCORE Internal", internal_path, class: "font-semibold text-slate-950" %>
          <% if respond_to?(:current_business_date, true) && current_business_date %>
            <span class="ml-3 text-sm text-slate-500">Business date <%= current_business_date.iso8601 %></span>
          <% end %>
        </div>

        <% if respond_to?(:current_operator, true) && current_operator %>
          <nav class="flex items-center gap-2 text-sm" aria-label="Global primary navigation">
            <% home_active = current_page?(internal_path) %>
            <%= link_to "Home", internal_path, class: bc_nav_link_class(active: home_active), aria: { current: ("page" if home_active) } %>
            <% if branch_access? %>
              <% branch_active = controller_path.start_with?("branch/") %>
              <%= link_to "Branch", branch_path, class: bc_nav_link_class(active: branch_active), aria: { current: ("page" if branch_active) } %>
            <% end %>
            <% if ops_access? %>
              <% ops_active = controller_path.start_with?("ops/") %>
              <%= link_to "Ops", ops_path, class: bc_nav_link_class(active: ops_active), aria: { current: ("page" if ops_active) } %>
            <% end %>
            <% if admin_access? %>
              <% admin_active = controller_path.start_with?("admin/") %>
              <%= link_to "Admin", admin_path, class: bc_nav_link_class(active: admin_active), aria: { current: ("page" if admin_active) } %>
            <% end %>
            <span class="text-slate-500"><%= current_operator.display_name.presence || current_operator.role.titleize %></span>
            <%= button_to "Sign out", logout_path, method: :delete, class: bc_button_class(:primary) %>
          </nav>
        <% end %>
      </div>
    </header>

    <main id="main-content" class="mx-auto max-w-6xl px-6 py-8" tabindex="-1">
      <% if controller_path.start_with?("branch/") %>
        <%= render "branch/shared/surface_nav" %>
      <% end %>
      <%= render "shared/internal/flash_region" %>

      <%= yield %>
    </main>
  </body>
</html>
