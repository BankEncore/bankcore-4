<% content_for :title, "End Authorized Signer - BankCORE" %>

<section>
  <h1 class="text-3xl font-semibold">End authorized signer</h1>
  <p class="mt-2 text-slate-600">Account <%= @account.account_number %></p>
</section>

<%= render "branch/shared/form_error", error_message: @error_message %>

<section class="mt-6 rounded border border-slate-200 bg-white p-6 shadow-sm">
  <h2 class="text-xl font-semibold"><%= @relationship.party_record.name %></h2>
  <dl class="mt-4 grid gap-4 text-sm md:grid-cols-2">
    <div><dt class="font-medium text-slate-500">Relationship</dt><dd>#<%= @relationship.id %></dd></div>
    <div><dt class="font-medium text-slate-500">Role</dt><dd><%= @relationship.role %></dd></div>
    <div><dt class="font-medium text-slate-500">Status</dt><dd><%= @relationship.status %></dd></div>
    <div><dt class="font-medium text-slate-500">Effective on</dt><dd><%= branch_date(@relationship.effective_on) %></dd></div>
  </dl>

  <%= form_with url: branch_end_account_authorized_signer_path(@account, @relationship), scope: :authorized_signer_end, class: "mt-6 grid gap-4 md:grid-cols-2" do |form| %>
    <div>
      <%= form.label :ended_on, "Ended on", class: "block text-sm font-medium text-slate-700" %>
      <%= form.date_field :ended_on, value: @authorized_signer_end["ended_on"], class: "mt-1 w-full rounded border border-slate-300 px-3 py-2" %>
    </div>
    <div>
      <%= form.label :idempotency_key, class: "block text-sm font-medium text-slate-700" %>
      <%= form.text_field :idempotency_key, value: @authorized_signer_end["idempotency_key"], class: "mt-1 w-full rounded border border-slate-300 px-3 py-2" %>
    </div>
    <div class="md:col-span-2 flex gap-3">
      <%= form.submit "End authorized signer", class: "rounded bg-slate-900 px-4 py-2 font-medium text-white" %>
      <%= link_to "Cancel", branch_servicing_deposit_account_path(@account), class: "rounded border border-slate-300 px-4 py-2 font-medium text-slate-700" %>
    </div>
  <% end %>
</section>
