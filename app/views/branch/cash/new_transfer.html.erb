<% content_for :title, "Transfer Cash - BankCORE" %>

<%= render "shared/internal/page_header",
  title: "Transfer cash",
  subtitle: "Move custody between branch cash locations." %>

<%= render "shared/internal/context_strip",
  business_date: current_business_date,
  operating_unit: current_operating_unit,
  operator: current_operator,
  state_items: [
    ["Locations", @locations.size],
    ["Channel", "branch"]
  ] %>

<%= render "branch/shared/form_error", error_message: @error_message if @error_message.present? %>
<%= render "branch/shared/transaction_preview", preview: @preview if @preview.present? %>

<%= render "shared/internal/page_section",
  title: "Transfer request",
  description: "Choose the source and destination cash locations, then record the amount and reason.",
  class: "mt-6",
  content: capture {
    form_with url: branch_cash_transfers_path, scope: :cash_transfer, class: "grid gap-4 md:grid-cols-2" do |form|
      safe_join([
        content_tag(:div) do
          safe_join([
            form.label(:source_cash_location_id, "Source location", class: "block text-sm font-medium text-slate-700"),
            form.collection_select(:source_cash_location_id, @locations, :id, :name, { selected: @cash_transfer["source_cash_location_id"] || @cash_transfer[:source_cash_location_id] }, class: "mt-1 w-full rounded border border-slate-300 px-3 py-2")
          ])
        end,
        content_tag(:div) do
          safe_join([
            form.label(:destination_cash_location_id, "Destination location", class: "block text-sm font-medium text-slate-700"),
            form.collection_select(:destination_cash_location_id, @locations, :id, :name, { selected: @cash_transfer["destination_cash_location_id"] || @cash_transfer[:destination_cash_location_id] }, class: "mt-1 w-full rounded border border-slate-300 px-3 py-2")
          ])
        end,
        content_tag(:div) do
          safe_join([
            form.label(:amount_minor_units, "Amount in cents", class: "block text-sm font-medium text-slate-700"),
            form.number_field(:amount_minor_units, min: 1, value: @cash_transfer["amount_minor_units"] || @cash_transfer[:amount_minor_units], class: "mt-1 w-full rounded border border-slate-300 px-3 py-2")
          ])
        end,
        content_tag(:div) do
          safe_join([
            form.label(:reason_code, "Reason", class: "block text-sm font-medium text-slate-700"),
            form.text_field(:reason_code, value: @cash_transfer["reason_code"] || @cash_transfer[:reason_code], class: "mt-1 w-full rounded border border-slate-300 px-3 py-2")
          ])
        end,
        content_tag(:div, class: "md:col-span-2") do
          safe_join([
            form.label(:idempotency_key, class: "block text-sm font-medium text-slate-700"),
            form.text_field(:idempotency_key, value: @cash_transfer["idempotency_key"] || @cash_transfer[:idempotency_key], class: "mt-1 w-full rounded border border-slate-300 px-3 py-2")
          ])
        end,
        content_tag(:div, class: "md:col-span-2 flex flex-wrap gap-3") do
          safe_join([
            form.submit("Record transfer", class: bc_button_class(:primary)),
            link_to("Cash position", branch_cash_path, class: bc_button_class(:secondary))
          ])
        end
      ])
    end
  } %>
