<% content_for :title, "Cash Result - BankCORE" %>

<%= render "shared/internal/page_header",
  title: "Cash result",
  subtitle: "Review committed Cash custody evidence." %>

<% if @cash_result_type == "transfer" && @movement.present? %>
  <%= render "shared/internal/context_strip",
    business_date: @movement.business_date,
    operating_unit: @movement.operating_unit,
    operator: current_operator,
    state_items: [
      ["Result type", "cash transfer"],
      ["Status", @movement.status],
      ["Channel", "branch"]
    ] %>

  <% if @movement.pending_approval? %>
    <%= render "shared/internal/status_banner",
      tone: :warning,
      title: "Approval required",
      body: "Cash movement approval and no-self-approval are enforced by the Cash command path." %>
  <% end %>

  <%= render "shared/internal/page_section",
    title: "Cash movement recorded",
    description: "Custody movement evidence for the branch transfer request.",
    class: "mt-6",
    content: capture {
      safe_join([
        content_tag(:dl, class: "grid gap-4 text-sm md:grid-cols-2") do
          safe_join([
            content_tag(:div) { safe_join([content_tag(:dt, "Cash movement", class: "font-medium text-slate-500"), content_tag(:dd, "##{@movement.id}")]) },
            content_tag(:div) { safe_join([content_tag(:dt, "Movement type", class: "font-medium text-slate-500"), content_tag(:dd, @movement.movement_type)]) },
            content_tag(:div) { safe_join([content_tag(:dt, "Status", class: "font-medium text-slate-500"), content_tag(:dd, @movement.status)]) },
            content_tag(:div) { safe_join([content_tag(:dt, "Business date", class: "font-medium text-slate-500"), content_tag(:dd, branch_date(@movement.business_date))]) },
            content_tag(:div) { safe_join([content_tag(:dt, "Actor", class: "font-medium text-slate-500"), content_tag(:dd, @movement.actor&.display_name || @movement.actor_id)]) },
            content_tag(:div) { safe_join([content_tag(:dt, "Approver", class: "font-medium text-slate-500"), content_tag(:dd, @movement.approving_actor&.display_name || @movement.approving_actor_id || "Pending or not required")]) },
            content_tag(:div) { safe_join([content_tag(:dt, "Source location", class: "font-medium text-slate-500"), content_tag(:dd, @movement.source_cash_location&.name || "None")]) },
            content_tag(:div) { safe_join([content_tag(:dt, "Destination location", class: "font-medium text-slate-500"), content_tag(:dd, @movement.destination_cash_location&.name || "None")]) },
            content_tag(:div) { safe_join([content_tag(:dt, "Amount", class: "font-medium text-slate-500"), content_tag(:dd, "#{branch_money(@movement.amount_minor_units)} #{@movement.currency}")]) },
            content_tag(:div) { safe_join([content_tag(:dt, "Idempotency key", class: "font-medium text-slate-500"), content_tag(:dd, @movement.idempotency_key)]) },
            content_tag(:div) { safe_join([content_tag(:dt, "Operational event", class: "font-medium text-slate-500"), content_tag(:dd, @movement.operational_event_id.present? ? "##{@movement.operational_event_id}" : "Pending approval; no event yet")]) },
            content_tag(:div) { safe_join([content_tag(:dt, "No-GL evidence", class: "font-medium text-slate-500"), content_tag(:dd, "Ordinary internal custody movement does not create journal entries.")]) }
          ])
        end,
        content_tag(:div, class: "mt-6 flex flex-wrap gap-3") do
          links = [link_to("Cash position", branch_cash_path, class: bc_button_class(:primary))]
          if @movement.operational_event_id.present?
            links << link_to("Event detail", branch_operational_event_path(@movement.operational_event_id), class: bc_button_class(:secondary))
            links << link_to("Trace receipt", branch_event_receipt_path(@movement.operational_event_id), class: bc_button_class(:secondary))
          end
          safe_join(links)
        end
      ])
    } %>
<% elsif @cash_result_type == "count" && @count.present? %>
  <% variance = @count.cash_variance %>
  <%= render "shared/internal/context_strip",
    business_date: @count.business_date,
    operating_unit: @count.operating_unit,
    operator: current_operator,
    state_items: [
      ["Result type", "cash count"],
      ["Status", @count.status],
      ["Variance", (variance.present? ? branch_money(variance.amount_minor_units, signed: true) : "None")]
    ] %>

  <% if variance.present? %>
    <%= render "shared/internal/status_banner",
      tone: :warning,
      title: "Variance approval required",
      body: "Variance approval and any GL adjustment are owned by the Cash variance command path." %>
  <% end %>

  <%= render "shared/internal/page_section",
    title: "Cash count recorded",
    description: "Count evidence and any variance generated from the recorded custody comparison.",
    class: "mt-6",
    content: capture {
      safe_join([
        content_tag(:dl, class: "grid gap-4 text-sm md:grid-cols-2") do
          safe_join([
            content_tag(:div) { safe_join([content_tag(:dt, "Cash count", class: "font-medium text-slate-500"), content_tag(:dd, "##{@count.id}")]) },
            content_tag(:div) { safe_join([content_tag(:dt, "Status", class: "font-medium text-slate-500"), content_tag(:dd, @count.status)]) },
            content_tag(:div) { safe_join([content_tag(:dt, "Business date", class: "font-medium text-slate-500"), content_tag(:dd, branch_date(@count.business_date))]) },
            content_tag(:div) { safe_join([content_tag(:dt, "Actor", class: "font-medium text-slate-500"), content_tag(:dd, @count.actor&.display_name || @count.actor_id)]) },
            content_tag(:div) { safe_join([content_tag(:dt, "Cash location", class: "font-medium text-slate-500"), content_tag(:dd, @count.cash_location.name)]) },
            content_tag(:div) { safe_join([content_tag(:dt, "Expected amount", class: "font-medium text-slate-500"), content_tag(:dd, "#{branch_money(@count.expected_amount_minor_units)} #{@count.currency}")]) },
            content_tag(:div) { safe_join([content_tag(:dt, "Counted amount", class: "font-medium text-slate-500"), content_tag(:dd, "#{branch_money(@count.counted_amount_minor_units)} #{@count.currency}")]) },
            content_tag(:div) { safe_join([content_tag(:dt, "Cash variance", class: "font-medium text-slate-500"), content_tag(:dd, variance.present? ? "##{variance.id} (#{variance.status}, #{branch_money(variance.amount_minor_units, signed: true)})" : "None")]) },
            content_tag(:div) { safe_join([content_tag(:dt, "Idempotency key", class: "font-medium text-slate-500"), content_tag(:dd, @count.idempotency_key)]) },
            content_tag(:div) { safe_join([content_tag(:dt, "Operational event", class: "font-medium text-slate-500"), content_tag(:dd, @count.operational_event_id.present? ? "##{@count.operational_event_id}" : "None")]) },
            content_tag(:div) { safe_join([content_tag(:dt, "No-GL evidence", class: "font-medium text-slate-500"), content_tag(:dd, "Count recording is no-GL; variance approval owns any GL adjustment.")]) }
          ])
        end,
        content_tag(:div, class: "mt-6 flex flex-wrap gap-3") do
          links = [link_to("Cash position", branch_cash_path, class: bc_button_class(:primary))]
          if @count.operational_event_id.present?
            links << link_to("Event detail", branch_operational_event_path(@count.operational_event_id), class: bc_button_class(:secondary))
            links << link_to("Trace receipt", branch_event_receipt_path(@count.operational_event_id), class: bc_button_class(:secondary))
          end
          safe_join(links)
        end
      ])
    } %>
<% end %>
