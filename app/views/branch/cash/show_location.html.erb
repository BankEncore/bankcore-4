<% location = @activity.fetch(:location) %>
<% content_for :title, "#{location.name} - BankCORE" %>

<%= render "shared/internal/page_header",
  title: location.name,
  subtitle: "#{location.location_type} / #{location.currency}",
  actions: capture {
    link_to "Cash position", branch_cash_path, class: bc_button_class(:secondary)
  } %>

<%= render "shared/internal/context_strip",
  business_date: current_business_date,
  operating_unit: current_operating_unit,
  operator: current_operator,
  state_items: [
    ["Location id", location.id],
    ["Type", location.location_type],
    ["Currency", location.currency]
  ] %>

<div class="mt-6 grid gap-6 lg:grid-cols-2">
  <%= render "shared/internal/page_section",
    title: "Recent movements",
    description: "Latest custody movements affecting this cash location.",
    content: capture {
      if @activity.fetch(:movements).any?
        content_tag(:ul, class: "space-y-2 text-sm") do
          safe_join(@activity.fetch(:movements).map do |movement|
            content_tag(:li, "##{movement.id} #{movement.movement_type} #{number_to_currency(movement.amount_minor_units / 100.0)} #{movement.status}")
          end)
        end
      else
        content_tag(:p, "No recent cash movements.", class: "text-sm text-slate-600")
      end
    } %>

  <%= render "shared/internal/page_section",
    title: "Recent counts and variances",
    description: "Latest count evidence and variance comparisons for this location.",
    content: capture {
      if @activity.fetch(:counts).any?
        content_tag(:ul, class: "space-y-2 text-sm") do
          safe_join(@activity.fetch(:counts).map do |count|
            content_tag(:li, "##{count.id} counted #{number_to_currency(count.counted_amount_minor_units / 100.0)}, expected #{number_to_currency(count.expected_amount_minor_units / 100.0)}")
          end)
        end
      else
        content_tag(:p, "No recent cash counts.", class: "text-sm text-slate-600")
      end
    } %>
</div>
