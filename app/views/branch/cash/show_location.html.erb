<% location = @activity.fetch(:location) %>
<% content_for :title, "#{location.name} - BankCORE" %>

<h1 class="text-3xl font-semibold"><%= location.name %></h1>
<p class="mt-2 text-slate-600"><%= location.location_type %> / <%= location.currency %></p>

<section class="mt-6 grid gap-6 lg:grid-cols-2">
  <div class="rounded border border-slate-200 bg-white p-5 shadow-sm">
    <h2 class="font-semibold">Recent movements</h2>
    <ul class="mt-3 space-y-2 text-sm">
      <% @activity.fetch(:movements).each do |movement| %>
        <li>#<%= movement.id %> <%= movement.movement_type %> <%= number_to_currency(movement.amount_minor_units / 100.0) %> <%= movement.status %></li>
      <% end %>
    </ul>
  </div>
  <div class="rounded border border-slate-200 bg-white p-5 shadow-sm">
    <h2 class="font-semibold">Recent counts and variances</h2>
    <ul class="mt-3 space-y-2 text-sm">
      <% @activity.fetch(:counts).each do |count| %>
        <li>#<%= count.id %> counted <%= number_to_currency(count.counted_amount_minor_units / 100.0) %>, expected <%= number_to_currency(count.expected_amount_minor_units / 100.0) %></li>
      <% end %>
    </ul>
  </div>
</section>
