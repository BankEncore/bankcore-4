<% content_for :title, "Cash Position - BankCORE" %>

<% cash_actions = capture do %>
  <%= link_to "Transfer cash", branch_new_cash_transfer_path, class: bc_button_class(:primary) %>
  <%= link_to "Receive shipment", branch_new_external_cash_shipment_path, class: bc_button_class(:secondary) %>
  <%= link_to "Record count", branch_new_cash_count_path, class: bc_button_class(:secondary) %>
<% end %>
<%= render "shared/internal/page_header",
  title: "Cash position",
  subtitle: "Branch vault and teller drawer custody balances.",
  actions: cash_actions %>

<%= render "shared/internal/context_strip",
  business_date: current_business_date,
  operating_unit: current_operating_unit,
  operator: current_operator,
  state_items: [
    ["Locations", @positions.size],
    ["Scope", "current custody state"]
  ] %>

<% cash_position_table = capture do %>
  <table class="min-w-full divide-y divide-slate-200 text-sm">
    <thead class="bg-slate-50 text-left text-slate-600">
      <tr>
        <th class="px-4 py-3">Location</th>
        <th class="px-4 py-3">Type</th>
        <th class="px-4 py-3">Drawer</th>
        <th class="px-4 py-3 text-right">Balance</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      <% @positions.each do |position| %>
        <tr>
          <td class="px-4 py-3"><%= link_to position.fetch(:name), branch_cash_location_path(position.fetch(:id)), class: "font-medium text-slate-900 underline" %></td>
          <td class="px-4 py-3"><%= position.fetch(:location_type) %></td>
          <td class="px-4 py-3"><%= position.fetch(:drawer_code).presence || "-" %></td>
          <td class="px-4 py-3 text-right"><%= number_to_currency(position.fetch(:amount_minor_units) / 100.0) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
<%= render "shared/internal/data_table",
  title: "Location balances",
  description: "Active branch cash locations and their current custody balances.",
  content: cash_position_table,
  empty: "No active cash locations are available for this operating unit.",
  class: "mt-6" %>
