<% content_for :title, "Record Cash Count - BankCORE" %>

<h1 class="text-3xl font-semibold">Record cash count</h1>
<%= render "branch/shared/form_error", error_message: @error_message if @error_message.present? %>

<%= form_with url: branch_cash_counts_path, scope: :cash_count, class: "mt-6 max-w-xl space-y-4 rounded border border-slate-200 bg-white p-5 shadow-sm" do |form| %>
  <div>
    <%= form.label :cash_location_id, "Location", class: "block text-sm font-medium text-slate-700" %>
    <%= form.collection_select :cash_location_id, @locations, :id, :name, { selected: @cash_count["cash_location_id"] || @cash_count[:cash_location_id] }, class: "mt-1 w-full rounded border-slate-300" %>
  </div>
  <div>
    <%= form.label :counted_amount_minor_units, "Counted amount in cents", class: "block text-sm font-medium text-slate-700" %>
    <%= form.number_field :counted_amount_minor_units, min: 0, value: @cash_count["counted_amount_minor_units"] || @cash_count[:counted_amount_minor_units], class: "mt-1 w-full rounded border-slate-300" %>
  </div>
  <div>
    <%= form.label :expected_amount_minor_units, "Expected amount in cents (optional)", class: "block text-sm font-medium text-slate-700" %>
    <%= form.number_field :expected_amount_minor_units, min: 0, value: @cash_count["expected_amount_minor_units"] || @cash_count[:expected_amount_minor_units], class: "mt-1 w-full rounded border-slate-300" %>
  </div>
  <div>
    <%= form.label :idempotency_key, class: "block text-sm font-medium text-slate-700" %>
    <%= form.text_field :idempotency_key, value: @cash_count["idempotency_key"] || @cash_count[:idempotency_key], class: "mt-1 w-full rounded border-slate-300" %>
    <p class="mt-1 text-xs text-slate-500">Keep this value stable when retrying the same count.</p>
  </div>
  <%= form.submit "Record count", class: "rounded bg-slate-900 px-4 py-2 font-medium text-white" %>
<% end %>
