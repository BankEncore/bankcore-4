<% content_for :title, "Receive Cash Shipment - BankCORE" %>

<%= render "shared/internal/page_header",
  title: "Receive external cash shipment",
  subtitle: "Record cash that has already arrived from the Federal Reserve or a correspondent bank into branch vault custody." %>

<%= render "shared/internal/context_strip",
  business_date: current_business_date,
  operating_unit: current_operating_unit,
  operator: current_operator,
  state_items: [
    ["Vault locations", @vault_locations.size],
    ["Channel", "branch"]
  ] %>

<%= render "branch/shared/form_error", error_message: @error_message if @error_message.present? %>

<%= render "shared/internal/page_section",
  title: "Shipment receipt",
  description: "Record the destination vault, cash amount, and external shipment reference for the custody receipt.",
  class: "mt-6",
  content: capture {
    form_with url: branch_external_cash_shipments_path, scope: :cash_shipment, class: "grid gap-4 md:grid-cols-2" do |form|
      safe_join([
        content_tag(:div) do
          safe_join([
            form.label(:destination_cash_location_id, "Destination vault", class: "block text-sm font-medium text-slate-700"),
            form.collection_select(:destination_cash_location_id, @vault_locations, :id, :name, {}, class: "mt-1 w-full rounded border border-slate-300 px-3 py-2")
          ])
        end,
        content_tag(:div) do
          safe_join([
            form.label(:amount_minor_units, "Amount in cents", class: "block text-sm font-medium text-slate-700"),
            form.number_field(:amount_minor_units, min: 1, class: "mt-1 w-full rounded border border-slate-300 px-3 py-2")
          ])
        end,
        content_tag(:div) do
          safe_join([
            form.label(:external_source, "External source", class: "block text-sm font-medium text-slate-700"),
            form.text_field(:external_source, placeholder: "Federal Reserve or correspondent bank", class: "mt-1 w-full rounded border border-slate-300 px-3 py-2")
          ])
        end,
        content_tag(:div) do
          safe_join([
            form.label(:shipment_reference, "Shipment reference", class: "block text-sm font-medium text-slate-700"),
            form.text_field(:shipment_reference, class: "mt-1 w-full rounded border border-slate-300 px-3 py-2")
          ])
        end,
        content_tag(:div, class: "md:col-span-2") do
          safe_join([
            form.label(:idempotency_key, "Idempotency key", class: "block text-sm font-medium text-slate-700"),
            form.text_field(:idempotency_key, class: "mt-1 w-full rounded border border-slate-300 px-3 py-2"),
            content_tag(:p, "Optional. Leave blank to generate a one-time receipt key.", class: "mt-1 text-xs text-slate-500")
          ])
        end,
        content_tag(:div, class: "md:col-span-2 flex flex-wrap gap-3") do
          safe_join([
            form.submit("Receive shipment", class: bc_button_class(:primary)),
            link_to("Cash position", branch_cash_path, class: bc_button_class(:secondary))
          ])
        end
      ])
    end
  } %>
