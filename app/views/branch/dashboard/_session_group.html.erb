<section class="mt-8 rounded border border-slate-200 bg-white shadow-sm">
  <div class="border-b border-slate-200 px-5 py-4">
    <h2 class="text-xl font-semibold"><%= title %></h2>
    <p class="mt-1 text-sm text-slate-600"><%= description %></p>
  </div>

  <% variance_approve = local_assigns.fetch(:variance_approve, false) %>
  <% if sessions.any? %>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-200 text-sm">
        <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
          <tr>
            <th class="px-5 py-3">Session</th>
            <th class="px-5 py-3">Drawer</th>
            <th class="px-5 py-3">Opened</th>
            <% if show_close_fields %>
              <th class="px-5 py-3">Closed</th>
              <th class="px-5 py-3 text-right">Expected</th>
              <th class="px-5 py-3 text-right">Actual</th>
              <th class="px-5 py-3 text-right">Variance</th>
              <th class="px-5 py-3">Supervisor</th>
              <% if variance_approve %>
                <th class="px-5 py-3">Actions</th>
              <% end %>
            <% else %>
              <th class="px-5 py-3">Close session</th>
            <% end %>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% sessions.each do |session| %>
            <tr>
              <td class="px-5 py-4">
                <div class="font-medium text-slate-950">#<%= session.id %></div>
                <% status_classes = case session.status
                  when Teller::Models::TellerSession::STATUS_PENDING_SUPERVISOR
                    "bg-amber-100 text-amber-900"
                  when Teller::Models::TellerSession::STATUS_CLOSED
                    "bg-emerald-100 text-emerald-900"
                  else
                    "bg-slate-100 text-slate-700"
                  end %>
                <div class="mt-1">
                  <span class="rounded-full px-2 py-0.5 text-xs font-medium <%= status_classes %>"><%= session.status.humanize %></span>
                </div>
              </td>
              <td class="px-5 py-4"><%= session.drawer_code.presence || "Default drawer" %></td>
              <td class="px-5 py-4"><%= branch_session_time(session.opened_at) %></td>
              <% if show_close_fields %>
                <td class="px-5 py-4"><%= branch_session_time(session.closed_at) %></td>
                <td class="px-5 py-4 text-right"><%= branch_money(session.expected_cash_minor_units) %></td>
                <td class="px-5 py-4 text-right"><%= branch_money(session.actual_cash_minor_units) %></td>
                <td class="px-5 py-4 text-right"><%= branch_money(session.variance_minor_units, signed: true) %></td>
                <td class="px-5 py-4">
                  <% if session.supervisor_approved_at.present? %>
                    <div><%= session.supervisor_operator&.display_name.presence || "Supervisor" %></div>
                    <div class="text-xs text-slate-500"><%= branch_session_time(session.supervisor_approved_at) %></div>
                  <% elsif session.status == Teller::Models::TellerSession::STATUS_PENDING_SUPERVISOR %>
                    <span class="font-medium text-amber-800">Approval required</span>
                  <% else %>
                    <span class="text-slate-500">Not required</span>
                  <% end %>
                </td>
                <% if variance_approve %>
                  <td class="px-5 py-4">
                    <% if session.status == Teller::Models::TellerSession::STATUS_PENDING_SUPERVISOR &&
                          session.supervisor_approved_at.blank? &&
                          branch_operator_can?(Workspace::Authorization::CapabilityRegistry::TELLER_SESSION_VARIANCE_APPROVE) %>
                      <%= form_with url: approve_variance_branch_teller_sessions_path, scope: :teller_session_approve_variance, method: :post, local: true, class: "inline" do |form| %>
                        <%= form.hidden_field :teller_session_id, value: session.id %>
                        <%= form.submit "Approve variance", class: "rounded bg-amber-800 px-3 py-1 text-sm font-medium text-white" %>
                      <% end %>
                    <% else %>
                      <span class="text-slate-400">—</span>
                    <% end %>
                  </td>
                <% end %>
              <% else %>
                <td class="px-5 py-4">
                  <% expected_cash_minor_units = branch_expected_cash_for(session) %>
                  <div class="mb-2 text-xs text-slate-600">
                    Expected cash: <span class="font-medium text-slate-950"><%= branch_money(expected_cash_minor_units) %></span>
                  </div>
                  <div class="mb-2 text-xs text-slate-500">
                    Variance is calculated as actual cash minus expected cash at close.
                  </div>
                  <%= form_with url: close_branch_teller_session_path(session), scope: :teller_session_close, method: :post, class: "grid gap-2 md:grid-cols-2" do |form| %>
                    <%= form.text_field :actual_cash_minor_units, placeholder: "Actual cash", class: "rounded border border-slate-300 px-2 py-1" %>
                    <%= form.submit "Close", class: "rounded bg-slate-900 px-3 py-1 font-medium text-white" %>
                  <% end %>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="px-5 py-8 text-sm text-slate-600"><%= empty_message %></div>
  <% end %>
</section>
