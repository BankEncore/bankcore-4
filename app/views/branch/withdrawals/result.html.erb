<% content_for :title, "Withdrawal Result - BankCORE" %>

<%= render "shared/internal/page_header",
  title: "Withdrawal result",
  subtitle: "Review the withdrawal event, posting outcome, or NSF denial." %>

<% if @denial_event.present? %>
  <%= render "shared/internal/context_strip",
    business_date: @denial_event.business_date,
    operating_unit: @denial_event.operating_unit,
    operator: current_operator,
    state_items: [
      ["Outcome", @outcome],
      ["Denial event", @denial_event.id],
      ["Fee event", @fee_event&.id || "None"]
    ] %>

  <%= render "shared/internal/status_banner",
    tone: :warning,
    title: "Withdrawal denied for NSF",
    body: capture {
      content_tag(:dl, class: "mt-2 grid gap-4 text-sm md:grid-cols-2") do
        safe_join([
          content_tag(:div) { safe_join([content_tag(:dt, "Denial event", class: "font-medium"), content_tag(:dd, "##{@denial_event.id}")]) },
          content_tag(:div) { safe_join([content_tag(:dt, "Fee event", class: "font-medium"), content_tag(:dd, "##{@fee_event.id}")]) },
          content_tag(:div) { safe_join([content_tag(:dt, "Outcome", class: "font-medium"), content_tag(:dd, @outcome)]) },
          content_tag(:div) { safe_join([content_tag(:dt, "Attempt amount", class: "font-medium"), content_tag(:dd, "#{branch_money(@denial_event.amount_minor_units)} #{@denial_event.currency}")]) }
        ])
      end
    } %>
<% else %>
  <%= render "shared/internal/context_strip",
    business_date: @event&.business_date || current_business_date,
    operating_unit: @event&.operating_unit || current_operating_unit,
    operator: current_operator,
    state_items: [
      ["Outcome", @outcome],
      ["Event type", @event&.event_type || "None"],
      ["Status", @event&.status || "None"]
    ] %>

  <%= render "branch/shared/transaction_result",
    title: "Withdrawal recorded",
    event: @event,
    outcome: @outcome,
    post_result: @post_result %>
<% end %>
