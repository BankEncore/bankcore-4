<% content_for :title, "Record Withdrawal - BankCORE" %>

<section>
  <h1 class="text-3xl font-semibold">Record withdrawal</h1>
  <p class="mt-2 text-slate-600">Create a teller-channel withdrawal event, with optional immediate posting.</p>
</section>

<%= render "branch/shared/transaction_form",
  path: branch_withdrawals_path,
  scope: :withdrawal,
  form_data: @withdrawal,
  error_message: @error_message,
  preview: @preview,
  submit_label: "Record withdrawal" %>
