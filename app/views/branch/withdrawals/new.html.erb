<% content_for :title, "Record Withdrawal - BankCORE" %>

<%= render "shared/internal/page_header",
  title: "Record withdrawal",
  subtitle: "Create a teller-channel withdrawal event, with optional immediate posting." %>

<%= render "shared/internal/context_strip",
  business_date: current_business_date,
  operating_unit: current_operating_unit,
  operator: current_operator,
  state_items: [
    ["Open sessions", @open_teller_sessions.size],
    ["Posting mode", "Teller cash transaction"]
  ] %>

<%= render "branch/shared/cash_transaction_form",
  path: branch_withdrawals_path,
  scope: :withdrawal,
  form_data: @withdrawal,
  error_message: @error_message,
  open_sessions: @open_teller_sessions,
  preview: @preview,
  submit_label: "Record withdrawal" %>
