<% current_surface = @branch_surface.presence || branch_surface_for_path %>
<nav class="mb-6 flex flex-wrap gap-2 border-b border-slate-200 pb-4 text-sm" aria-label="Branch surface navigation" data-surface-nav data-current-surface="<%= current_surface %>">
  <%= link_to "CSR", branch_customers_path, class: bc_nav_link_class(active: current_surface == "csr", tone: :surface), data: { surface_tab: "csr" }, aria: { current: ("true" if current_surface == "csr") } %>
  <%= link_to "Teller", branch_teller_path, class: bc_nav_link_class(active: current_surface == "teller", tone: :surface), data: { surface_tab: "teller" }, aria: { current: ("true" if current_surface == "teller") } %>
  <%= link_to "Supervisor", branch_approvals_path, class: bc_nav_link_class(active: current_surface == "supervisor", tone: :surface), data: { surface_tab: "supervisor" }, aria: { current: ("true" if current_surface == "supervisor") } %>
  <%= link_to "Events", branch_events_path, class: bc_nav_link_class(active: current_surface == "events", tone: :surface), data: { surface_tab: "events" }, aria: { current: ("true" if current_surface == "events") } %>
</nav>

<script>
  (() => {
    const nav = document.querySelector("[data-surface-nav]");
    if (!nav) return;

    const tabs = Array.from(nav.querySelectorAll("[data-surface-tab]"));
    const currentSurface = () => {
      const hashSurface = window.location.hash.replace("#", "");
      return hashSurface || nav.dataset.currentSurface || "csr";
    };

    const applyActiveState = () => {
      const surface = currentSurface();
      tabs.forEach((tab) => {
        const isActive = tab.dataset.surfaceTab === surface;
        if (isActive) {
          tab.setAttribute("aria-current", "true");
        } else {
          tab.removeAttribute("aria-current");
        }
      });
    };

    applyActiveState();
    window.addEventListener("hashchange", applyActiveState);
  })();
</script>
