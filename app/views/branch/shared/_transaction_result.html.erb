<section class="<%= bc_panel_class(tone: :default) %> mt-6 p-6">
  <h2 class="text-xl font-semibold"><%= title %></h2>

  <% if event.present? %>
    <dl class="mt-4 grid gap-4 text-sm md:grid-cols-2">
      <div><dt class="font-medium text-slate-500">Operational event</dt><dd>#<%= event.id %></dd></div>
      <div><dt class="font-medium text-slate-500">Event type</dt><dd><%= event.event_type %></dd></div>
      <div><dt class="font-medium text-slate-500">Status</dt><dd><%= event.status %></dd></div>
      <div><dt class="font-medium text-slate-500">Record outcome</dt><dd><%= outcome %></dd></div>
      <div><dt class="font-medium text-slate-500">Channel</dt><dd><%= event.channel %></dd></div>
      <div><dt class="font-medium text-slate-500">Actor</dt><dd><%= event.actor&.display_name || event.actor_id || "None" %></dd></div>
      <div><dt class="font-medium text-slate-500">Operating unit</dt><dd><%= event.operating_unit_id || "None" %></dd></div>
      <div><dt class="font-medium text-slate-500">Business date</dt><dd><%= branch_date(event.business_date) %></dd></div>
      <div><dt class="font-medium text-slate-500">Idempotency key</dt><dd><%= event.idempotency_key %></dd></div>
      <div><dt class="font-medium text-slate-500">Reference</dt><dd><%= event.reference_id.presence || "None" %></dd></div>
      <div><dt class="font-medium text-slate-500">Source account</dt><dd><%= event.source_account_id.present? ? "##{event.source_account_id}" : "None" %></dd></div>
      <div><dt class="font-medium text-slate-500">Destination account</dt><dd><%= event.destination_account_id.present? ? "##{event.destination_account_id}" : "None" %></dd></div>
      <div><dt class="font-medium text-slate-500">Teller session</dt><dd><%= event.teller_session_id.present? ? "##{event.teller_session_id}" : "None" %></dd></div>
      <div><dt class="font-medium text-slate-500">Amount</dt><dd><%= branch_money(event.amount_minor_units) %> <%= event.currency %></dd></div>
      <% if post_result.present? %>
        <div><dt class="font-medium text-slate-500">Post outcome</dt><dd><%= post_result[:outcome] %></dd></div>
      <% end %>
      <% hold_record = local_assigns[:hold] %>
      <% if hold_record.present? %>
        <div>
          <dt class="font-medium text-slate-500">Hold placed</dt>
          <dd>#<%= hold_record.id %> — <%= branch_money(hold_record.amount_minor_units) %> <%= hold_record.currency %> (<%= hold_record.status %>)</dd>
        </div>
        <% if hold_record.expires_on.present? %>
          <div>
            <dt class="font-medium text-slate-500">Hold scheduled release</dt>
            <dd><%= branch_date(hold_record.expires_on) %></dd>
          </div>
        <% end %>
      <% end %>
      <div>
        <dt class="font-medium text-slate-500">Posting batches</dt>
        <dd><%= event.posting_batches.map { |batch| "##{batch.id}" }.presence&.join(", ") || "None" %></dd>
      </div>
      <div>
        <dt class="font-medium text-slate-500">Journal entries</dt>
        <dd><%= event.journal_entries.map { |entry| "##{entry.id}" }.presence&.join(", ") || "None" %></dd>
      </div>
    </dl>

    <% if event.status == Core::OperationalEvents::Models::OperationalEvent::STATUS_PENDING %>
      <div class="mt-6 flex flex-wrap gap-3">
        <%= button_to "Post event", branch_event_post_path(event), method: :post, class: bc_button_class(:primary) %>
        <%= link_to "Event detail", branch_operational_event_path(event), class: bc_button_class(:secondary) %>
        <%= link_to "Trace receipt", branch_event_receipt_path(event), class: bc_button_class(:secondary) %>
        <% if event.source_account_id.present? %>
          <%= link_to "Source account", branch_account_path(event.source_account_id), class: bc_button_class(:secondary) %>
          <%= link_to "Source activity", branch_account_activity_path(event.source_account_id), class: bc_button_class(:secondary) %>
        <% end %>
        <% if event.destination_account_id.present? %>
          <%= link_to "Destination account", branch_account_path(event.destination_account_id), class: bc_button_class(:secondary) %>
          <%= link_to "Destination activity", branch_account_activity_path(event.destination_account_id), class: bc_button_class(:secondary) %>
        <% end %>
      </div>
    <% else %>
      <div class="mt-6 flex flex-wrap gap-3">
        <%= link_to "Event detail", branch_operational_event_path(event), class: bc_button_class(:primary) %>
        <%= link_to "Trace receipt", branch_event_receipt_path(event), class: bc_button_class(:secondary) %>
        <% if event.source_account_id.present? %>
          <%= link_to "Source account", branch_account_path(event.source_account_id), class: bc_button_class(:secondary) %>
          <%= link_to "Source activity", branch_account_activity_path(event.source_account_id), class: bc_button_class(:secondary) %>
        <% end %>
        <% if event.destination_account_id.present? %>
          <%= link_to "Destination account", branch_account_path(event.destination_account_id), class: bc_button_class(:secondary) %>
          <%= link_to "Destination activity", branch_account_activity_path(event.destination_account_id), class: bc_button_class(:secondary) %>
        <% end %>
      </div>
    <% end %>
  <% end %>
</section>
