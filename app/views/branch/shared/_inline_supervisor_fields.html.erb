<fieldset class="mt-3 grid gap-2 rounded border border-amber-200 bg-amber-50 p-3 md:grid-cols-2">
  <legend class="px-1 text-xs font-semibold uppercase tracking-wide text-amber-900">Inline supervisor approval</legend>
  <div>
    <%= form.label :supervisor_username, "Supervisor username", class: "block text-xs font-medium text-amber-900" %>
    <%= form.text_field :supervisor_username, name: "#{scope}[supervisor_username]", autocomplete: "username", class: "mt-1 w-full rounded border border-amber-300 px-2 py-1 text-sm" %>
  </div>
  <div>
    <%= form.label :supervisor_password, "Supervisor password", class: "block text-xs font-medium text-amber-900" %>
    <%= form.password_field :supervisor_password, name: "#{scope}[supervisor_password]", autocomplete: "current-password", class: "mt-1 w-full rounded border border-amber-300 px-2 py-1 text-sm" %>
  </div>
  <p class="text-xs text-amber-900 md:col-span-2">Credentials are checked once and are not stored. Approval still runs through the command-owned capability gate.</p>
</fieldset>
