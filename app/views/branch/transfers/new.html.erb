<% content_for :title, "Record Transfer - BankCORE" %>

<section>
  <h1 class="text-3xl font-semibold">Record transfer</h1>
  <p class="mt-2 text-slate-600">Create a teller-channel transfer event, with optional immediate posting.</p>
</section>

<%= render "branch/shared/transaction_form",
  path: branch_transfers_path,
  scope: :transfer,
  form_data: @transfer,
  error_message: @error_message,
  preview: @preview,
  account_fields: [
    [ :source_account_id, "Source account id", :source_account_number ],
    [ :destination_account_id, "Destination account id", :destination_account_number ]
  ],
  include_teller_session: false,
  submit_label: "Record transfer" %>
