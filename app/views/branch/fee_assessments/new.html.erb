<% content_for :title, "Assess Fee - BankCORE" %>

<section>
  <h1 class="text-3xl font-semibold">Assess fee</h1>
  <p class="mt-2 text-slate-600">Account <%= @account.account_number %></p>
</section>

<%= render "branch/shared/form_error", error_message: @error_message %>
<%= render "branch/shared/transaction_preview", preview: @preview if @preview.present? %>

<section class="mt-6 rounded border border-slate-200 bg-white p-6 shadow-sm">
  <%= form_with url: branch_fee_assessments_path(@account), scope: :fee_assessment, class: "grid gap-4 md:grid-cols-2" do |form| %>
    <div>
      <%= form.label :amount_minor_units, "Amount minor units", class: "block text-sm font-medium text-slate-700" %>
      <%= form.text_field :amount_minor_units, value: @fee_assessment["amount_minor_units"] || @fee_assessment[:amount_minor_units], class: "mt-1 w-full rounded border border-slate-300 px-3 py-2" %>
    </div>
    <div>
      <%= form.label :currency, class: "block text-sm font-medium text-slate-700" %>
      <%= form.text_field :currency, value: @fee_assessment["currency"] || @fee_assessment[:currency] || "USD", class: "mt-1 w-full rounded border border-slate-300 px-3 py-2" %>
    </div>
    <div>
      <%= form.label :reference_id, "Reference or memo", class: "block text-sm font-medium text-slate-700" %>
      <%= form.text_field :reference_id, value: @fee_assessment["reference_id"] || @fee_assessment[:reference_id], class: "mt-1 w-full rounded border border-slate-300 px-3 py-2" %>
    </div>
    <div>
      <%= form.label :idempotency_key, class: "block text-sm font-medium text-slate-700" %>
      <%= form.text_field :idempotency_key, value: @fee_assessment["idempotency_key"] || @fee_assessment[:idempotency_key], class: "mt-1 w-full rounded border border-slate-300 px-3 py-2" %>
      <p class="mt-1 text-xs text-slate-500">Keep this value stable when retrying the same fee assessment.</p>
    </div>
    <div class="md:col-span-2">
      <label class="flex items-center gap-2 text-sm text-slate-700">
        <%= form.check_box :record_and_post, { checked: ActiveModel::Type::Boolean.new.cast(@fee_assessment["record_and_post"] || @fee_assessment[:record_and_post]) }, "1", "0" %>
        Record and post immediately
      </label>
    </div>
    <div class="md:col-span-2">
      <%= form.submit "Assess fee", class: "rounded bg-slate-900 px-4 py-2 font-medium text-white" %>
      <%= link_to "Back to account", branch_servicing_deposit_account_path(@account), class: "ml-3 text-sm font-medium text-slate-700" %>
    </div>
  <% end %>
</section>
