<% content_for :title, "Restrict account #{@account.account_number} - BankCORE" %>

<%= render "branch/shared/account_context", active_tab: "overview", show_actions: false %>

<section class="mx-auto mt-6 max-w-3xl">
  <h1 class="text-3xl font-semibold">Restrict account</h1>
  <p class="mt-2 text-slate-600">Apply an account-control restriction. This records a no-GL operational event.</p>

  <%= render "branch/shared/form_error", error_message: @error_message %>

  <%= form_with url: branch_account_restrictions_path(@account), scope: :restriction, method: :post, class: "mt-6 rounded border border-slate-200 bg-white p-6 shadow-sm" do |form| %>
    <div class="grid gap-4 md:grid-cols-2">
      <div>
        <%= form.label :restriction_type, class: "block text-sm font-medium text-slate-700" %>
        <%= form.select :restriction_type,
          Accounts::Models::AccountRestriction::RESTRICTION_TYPES.map { |type| [type.humanize, type] },
          { selected: @restriction["restriction_type"] },
          class: "mt-1 w-full rounded border border-slate-300 px-3 py-2" %>
      </div>
      <div>
        <%= form.label :effective_on, class: "block text-sm font-medium text-slate-700" %>
        <%= form.date_field :effective_on, value: @restriction["effective_on"], class: "mt-1 w-full rounded border border-slate-300 px-3 py-2" %>
      </div>
      <div>
        <%= form.label :reason_code, class: "block text-sm font-medium text-slate-700" %>
        <%= form.text_field :reason_code, value: @restriction["reason_code"], required: true, class: "mt-1 w-full rounded border border-slate-300 px-3 py-2" %>
      </div>
      <div>
        <%= form.label :idempotency_key, class: "block text-sm font-medium text-slate-700" %>
        <%= form.text_field :idempotency_key, value: @restriction["idempotency_key"], required: true, class: "mt-1 w-full rounded border border-slate-300 px-3 py-2" %>
      </div>
      <div class="md:col-span-2">
        <%= form.label :reason_description, class: "block text-sm font-medium text-slate-700" %>
        <%= form.text_area :reason_description, value: @restriction["reason_description"], rows: 3, class: "mt-1 w-full rounded border border-slate-300 px-3 py-2" %>
      </div>
    </div>

    <div class="mt-6 flex gap-3">
      <%= form.submit "Record restriction", class: "rounded bg-slate-900 px-4 py-2 font-medium text-white" %>
      <%= link_to "Cancel", branch_account_path(@account), class: "rounded border border-slate-300 px-4 py-2 font-medium text-slate-700" %>
    </div>
  <% end %>
</section>
