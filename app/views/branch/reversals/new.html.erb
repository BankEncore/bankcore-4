<% content_for :title, "Record Reversal - BankCORE" %>

<%= render "shared/internal/page_header",
  title: "Record reversal",
  subtitle: "Supervisor-only compensating reversal for a posted financial event." %>

<%= render "shared/internal/context_strip",
  business_date: current_business_date,
  operating_unit: current_operating_unit,
  operator: current_operator,
  state_items: [
    ["Approval state", "Supervisor controlled"],
    ["Posting mode", "Compensating reversal"]
  ] %>

<%= render "branch/shared/form_error", error_message: @error_message %>

<%= render "shared/internal/status_banner",
  tone: :warning,
  title: "Supervisor-controlled action",
  body: "Reversal eligibility is enforced by RecordReversal and posting commands. This screen previews the original event and submits the supervisor-controlled request." %>

<% if @original_event_preview.present? %>
  <section class="mt-6 rounded border border-slate-200 bg-white p-6 shadow-sm">
    <h2 class="text-xl font-semibold">Original event preview</h2>
    <% if @original_event_preview[:missing_event_id].present? %>
      <p class="mt-3 text-sm text-rose-700">Operational event #<%= @original_event_preview[:missing_event_id] %> was not found.</p>
    <% else %>
      <dl class="mt-4 grid gap-4 text-sm md:grid-cols-2">
        <div><dt class="font-medium text-slate-500">Operational event</dt><dd>#<%= @original_event_preview[:id] %></dd></div>
        <div><dt class="font-medium text-slate-500">Event type</dt><dd><%= @original_event_preview[:event_type] %></dd></div>
        <div><dt class="font-medium text-slate-500">Status</dt><dd><%= @original_event_preview[:status] %></dd></div>
        <div><dt class="font-medium text-slate-500">Business date</dt><dd><%= branch_date(@original_event_preview[:business_date]) %></dd></div>
        <div><dt class="font-medium text-slate-500">Source account</dt><dd><%= @original_event_preview[:source_account_id].present? ? "##{@original_event_preview[:source_account_id]}" : "None" %></dd></div>
        <div><dt class="font-medium text-slate-500">Destination account</dt><dd><%= @original_event_preview[:destination_account_id].present? ? "##{@original_event_preview[:destination_account_id]}" : "None" %></dd></div>
        <div><dt class="font-medium text-slate-500">Amount</dt><dd><%= branch_money(@original_event_preview[:amount_minor_units]) %> <%= @original_event_preview[:currency] %></dd></div>
        <div><dt class="font-medium text-slate-500">Posting expected</dt><dd><%= @original_event_preview[:posting_expected] ? "Yes" : "No" %></dd></div>
        <div><dt class="font-medium text-slate-500">Reversed by</dt><dd><%= @original_event_preview[:reversed_by_event_id].present? ? "##{@original_event_preview[:reversed_by_event_id]}" : "Not reversed" %></dd></div>
        <div><dt class="font-medium text-slate-500">Is reversal of</dt><dd><%= @original_event_preview[:reversal_of_event_id].present? ? "##{@original_event_preview[:reversal_of_event_id]}" : "No" %></dd></div>
      </dl>
    <% end %>
  </section>
<% end %>

<section class="<%= bc_panel_class(tone: :default) %> mt-6 p-6">
  <%= form_with url: branch_reversals_path,
    scope: :reversal,
    method: :post,
    class: "space-y-6",
    data: {
      controller: "submit-state",
      action: "turbo:submit-start->submit-state#start turbo:submit-end->submit-state#end"
    } do |form| %>
    <%= render "shared/internal/form_section",
      title: "Original event context",
      description: "Identify the posted financial event that will be reversed." do %>
      <div class="grid gap-4 md:grid-cols-2">
        <div>
          <%= form.label :original_operational_event_id, "Original event id", class: "block text-sm font-medium text-slate-700" %>
          <%= form.text_field :original_operational_event_id, value: @reversal["original_operational_event_id"] || @reversal[:original_operational_event_id], class: "mt-1 w-full rounded border border-slate-300 px-3 py-2" %>
        </div>
        <div>
          <%= form.label :idempotency_key, class: "block text-sm font-medium text-slate-700" %>
          <%= form.text_field :idempotency_key, value: @reversal["idempotency_key"] || @reversal[:idempotency_key], class: "mt-1 w-full rounded border border-slate-300 px-3 py-2" %>
        </div>
      </div>
    <% end %>

    <%= render "shared/internal/form_section",
      title: "Review and submit",
      description: "This action creates a compensating reversal and can post it immediately when eligible." do %>
      <label class="flex items-center gap-2 text-sm text-slate-700">
        <%= form.check_box :record_and_post, { checked: ActiveModel::Type::Boolean.new.cast(@reversal["record_and_post"] || @reversal[:record_and_post]) }, "1", "0" %>
        Record and post immediately
      </label>
      <div>
        <%= form.submit "Record reversal", class: bc_button_class(:danger), data: { submitting_label: "Submitting..." } %>
      </div>
    <% end %>
  <% end %>
</section>
