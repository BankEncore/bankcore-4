<% content_for :title, "Hold Result - BankCORE" %>

<%= render "shared/internal/page_header",
  title: "Hold result",
  subtitle: "Review the servicing event and hold row." %>

<%= render "shared/internal/context_strip",
  business_date: @event.business_date,
  operating_unit: @event.operating_unit,
  operator: current_operator,
  state_items: [
    ["Outcome", @outcome],
    ["Event type", @event.event_type],
    ["Channel", @event.channel]
  ] %>

<%= render "shared/internal/page_section",
  title: @event.event_type,
  description: "Servicing hold evidence across the hold row and operational-event layer.",
  class: "mt-6",
  content: capture {
    safe_join([
      content_tag(:dl, class: "grid gap-4 text-sm md:grid-cols-2") do
        safe_join([
          content_tag(:div) { safe_join([content_tag(:dt, "Hold", class: "font-medium text-slate-500"), content_tag(:dd, "##{@hold_record.id} (#{@hold_record.status})")]) },
          content_tag(:div) { safe_join([content_tag(:dt, "Operational event", class: "font-medium text-slate-500"), content_tag(:dd, "##{@event.id}")]) },
          content_tag(:div) { safe_join([content_tag(:dt, "Outcome", class: "font-medium text-slate-500"), content_tag(:dd, @outcome)]) },
          content_tag(:div) { safe_join([content_tag(:dt, "Channel", class: "font-medium text-slate-500"), content_tag(:dd, @event.channel)]) },
          content_tag(:div) { safe_join([content_tag(:dt, "Actor", class: "font-medium text-slate-500"), content_tag(:dd, @event.actor&.display_name || @event.actor_id || "None")]) },
          content_tag(:div) { safe_join([content_tag(:dt, "Business date", class: "font-medium text-slate-500"), content_tag(:dd, branch_date(@event.business_date))]) },
          content_tag(:div) { safe_join([content_tag(:dt, "Idempotency key", class: "font-medium text-slate-500"), content_tag(:dd, @event.idempotency_key)]) },
          content_tag(:div) { safe_join([content_tag(:dt, "Account", class: "font-medium text-slate-500"), content_tag(:dd, "##{@event.source_account_id}")]) },
          content_tag(:div) { safe_join([content_tag(:dt, "Amount", class: "font-medium text-slate-500"), content_tag(:dd, "#{branch_money(@event.amount_minor_units)} #{@event.currency}")]) },
          content_tag(:div) { safe_join([content_tag(:dt, "Hold type", class: "font-medium text-slate-500"), content_tag(:dd, @hold_record.hold_type.humanize)]) },
          content_tag(:div) { safe_join([content_tag(:dt, "Reason", class: "font-medium text-slate-500"), content_tag(:dd, @hold_record.reason_code.humanize)]) },
          content_tag(:div) { safe_join([content_tag(:dt, "Customer explanation", class: "font-medium text-slate-500"), content_tag(:dd, @hold_record.customer_explanation)]) },
          content_tag(:div) { safe_join([content_tag(:dt, "Expires on", class: "font-medium text-slate-500"), content_tag(:dd, branch_date(@hold_record.expires_on))]) }
        ])
      end,
      content_tag(:div, class: "mt-6 flex flex-wrap gap-3") do
        safe_join([
          link_to("Back to account", branch_servicing_deposit_account_path(@account), class: bc_button_class(:primary)),
          link_to("Event detail", branch_operational_event_path(@event), class: bc_button_class(:secondary))
        ])
      end
    ])
  } %>
