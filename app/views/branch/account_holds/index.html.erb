<% content_for :title, "Account Holds - BankCORE" %>

<%= render "branch/shared/account_context", active_tab: "holds" %>

<%= render "branch/shared/form_error", error_message: @error_message %>

<section class="mt-6 rounded border border-slate-200 bg-white p-5 shadow-sm">
  <p class="text-sm font-medium text-slate-500">Active hold total</p>
  <p class="mt-2 text-2xl font-semibold"><%= branch_money(@holds.active_total_minor_units) %></p>
</section>

<section class="mt-6 overflow-hidden rounded border border-slate-200 bg-white shadow-sm">
  <%= render "branch/shared/hold_table", holds: @holds.holds, can_release: can_release_servicing_hold? %>
</section>
