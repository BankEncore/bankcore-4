<% content_for :title, "Release Hold - BankCORE" %>

<%= render "shared/internal/page_header",
  title: "Release hold",
  subtitle: "Release an active hold and record a no-GL hold release event." %>

<%= render "shared/internal/context_strip",
  business_date: current_business_date,
  operating_unit: current_operating_unit,
  operator: current_operator,
  state_items: [
    ["Channel", "branch"],
    ["Workflow", "no-GL hold release"]
  ] %>

<%= render "branch/shared/form_error", error_message: @error_message %>

<%= render "shared/internal/page_section",
  title: "Release request",
  description: "Hold release is capability-gated and remains no-GL. The release command verifies the hold is active before recording evidence.",
  class: "mt-6",
  content: capture {
    form_with url: release_branch_holds_path, scope: :hold_release, method: :post, class: "grid gap-4 md:grid-cols-2" do |form|
      safe_join([
        content_tag(:div) do
          safe_join([
            form.label(:hold_id, "Hold id", class: "block text-sm font-medium text-slate-700"),
            form.text_field(:hold_id, value: @hold_release["hold_id"] || @hold_release[:hold_id], class: "mt-1 w-full rounded border border-slate-300 px-3 py-2")
          ])
        end,
        content_tag(:div) do
          safe_join([
            form.label(:idempotency_key, class: "block text-sm font-medium text-slate-700"),
            form.text_field(:idempotency_key, value: @hold_release["idempotency_key"] || @hold_release[:idempotency_key], class: "mt-1 w-full rounded border border-slate-300 px-3 py-2")
          ])
        end,
        content_tag(:div, class: "md:col-span-2 flex flex-wrap gap-3") do
          safe_join([
            form.submit("Release hold", class: bc_button_class(:primary)),
            link_to("Place hold", new_branch_hold_path, class: bc_button_class(:secondary))
          ])
        end
      ])
    end
  } %>
