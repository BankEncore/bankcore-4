<% content_for :title, "Trace Receipt ##{@event.id} - BankCORE" %>

<section class="flex flex-col justify-between gap-4 md:flex-row md:items-end">
  <div>
    <h1 class="text-3xl font-semibold">Trace receipt #<%= @event.id %></h1>
    <p class="mt-2 text-slate-600">Receipt-style support evidence from immutable operational and posting records.</p>
  </div>
  <div class="flex flex-wrap gap-3">
    <%= link_to "Event detail", branch_operational_event_path(@event), class: "rounded border border-slate-300 px-4 py-2 font-medium text-slate-700" %>
    <%= link_to "Back to events", branch_operational_events_path, class: "rounded border border-slate-300 px-4 py-2 font-medium text-slate-700" %>
  </div>
</section>

<section class="mt-6 rounded border border-slate-200 bg-white p-6 shadow-sm">
  <h2 class="text-xl font-semibold"><%= @event.event_type %></h2>
  <dl class="mt-4 grid gap-4 text-sm md:grid-cols-2">
    <div><dt class="font-medium text-slate-500">Business date</dt><dd><%= branch_date(@event.business_date) %></dd></div>
    <div><dt class="font-medium text-slate-500">Recorded at</dt><dd><%= @event.created_at.in_time_zone.strftime("%Y-%m-%d %H:%M") %></dd></div>
    <div><dt class="font-medium text-slate-500">Status</dt><dd><%= @event.status %></dd></div>
    <div><dt class="font-medium text-slate-500">Channel</dt><dd><%= @event.channel %></dd></div>
    <div><dt class="font-medium text-slate-500">Operator</dt><dd><%= @event.actor&.display_name || @event.actor_id || "None" %></dd></div>
    <div><dt class="font-medium text-slate-500">Teller session</dt><dd><%= @event.teller_session_id.present? ? "##{@event.teller_session_id}" : "None" %></dd></div>
    <div><dt class="font-medium text-slate-500">Source account</dt><dd><%= @event.source_account&.account_number || @event.source_account_id || "None" %></dd></div>
    <div><dt class="font-medium text-slate-500">Destination account</dt><dd><%= @event.destination_account&.account_number || @event.destination_account_id || "None" %></dd></div>
    <div><dt class="font-medium text-slate-500">Amount</dt><dd><%= branch_money(@event.amount_minor_units) %> <%= @event.currency %></dd></div>
    <div><dt class="font-medium text-slate-500">Reference</dt><dd><%= @event.reference_id.presence || "None" %></dd></div>
    <div><dt class="font-medium text-slate-500">Idempotency key</dt><dd><%= @event.idempotency_key %></dd></div>
    <div><dt class="font-medium text-slate-500">Reversal linkage</dt><dd><%= @event.reversal_of_event_id.present? ? "Reversal of ##{@event.reversal_of_event_id}" : (@event.reversed_by_event_id.present? ? "Reversed by ##{@event.reversed_by_event_id}" : "None") %></dd></div>
    <div><dt class="font-medium text-slate-500">Posting batches</dt><dd><%= @event.posting_batches.map { |batch| "##{batch.id}" }.presence&.join(", ") || "None" %></dd></div>
    <div><dt class="font-medium text-slate-500">Journal entries</dt><dd><%= @event.journal_entries.map { |entry| "##{entry.id}" }.presence&.join(", ") || "None" %></dd></div>
  </dl>
</section>
