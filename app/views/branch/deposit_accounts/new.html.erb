<% content_for :title, "Open Deposit Account - BankCORE" %>

<section>
  <h1 class="text-3xl font-semibold">Open deposit account</h1>
  <p class="mt-2 text-slate-600">Open a deposit account for an existing party id.</p>
</section>

<%= render "branch/shared/form_error", error_message: @error_message %>

<section class="mt-6 rounded border border-slate-200 bg-white p-6 shadow-sm">
  <%= form_with url: branch_deposit_accounts_path, scope: :deposit_account, method: :post, class: "grid gap-4 md:grid-cols-2" do |form| %>
    <div>
      <%= form.label :party_record_id, "Primary party id", class: "block text-sm font-medium text-slate-700" %>
      <%= form.text_field :party_record_id, value: @deposit_account["party_record_id"] || @deposit_account[:party_record_id], class: "mt-1 w-full rounded border border-slate-300 px-3 py-2" %>
    </div>
    <div>
      <%= form.label :joint_party_record_id, "Joint party id (optional)", class: "block text-sm font-medium text-slate-700" %>
      <%= form.text_field :joint_party_record_id, value: @deposit_account["joint_party_record_id"] || @deposit_account[:joint_party_record_id], class: "mt-1 w-full rounded border border-slate-300 px-3 py-2" %>
    </div>
    <div>
      <%= form.label :deposit_product_id, "Deposit product id (optional)", class: "block text-sm font-medium text-slate-700" %>
      <%= form.text_field :deposit_product_id, value: @deposit_account["deposit_product_id"] || @deposit_account[:deposit_product_id], class: "mt-1 w-full rounded border border-slate-300 px-3 py-2" %>
    </div>
    <div>
      <%= form.label :product_code, "Product code (optional)", class: "block text-sm font-medium text-slate-700" %>
      <%= form.text_field :product_code, value: @deposit_account["product_code"] || @deposit_account[:product_code], class: "mt-1 w-full rounded border border-slate-300 px-3 py-2" %>
    </div>
    <div class="md:col-span-2">
      <%= form.submit "Open account", class: "rounded bg-slate-900 px-4 py-2 font-medium text-white" %>
    </div>
  <% end %>
</section>
