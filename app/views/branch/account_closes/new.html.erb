<% content_for :title, "Close account #{@account.account_number} - BankCORE" %>

<section class="mx-auto max-w-3xl">
  <div>
    <h1 class="text-3xl font-semibold">Close account <%= @account.account_number %></h1>
    <p class="mt-2 text-slate-600">Close is explicit, audited, and allowed only after balance, hold, pending-event, and restriction checks pass.</p>
  </div>

  <%= render "branch/shared/form_error", error_message: @error_message %>

  <%= form_with url: branch_close_account_path(@account), scope: :account_close, method: :post, class: "mt-6 rounded border border-slate-200 bg-white p-6 shadow-sm" do |form| %>
    <div class="grid gap-4 md:grid-cols-2">
      <div>
        <%= form.label :effective_on, class: "block text-sm font-medium text-slate-700" %>
        <%= form.date_field :effective_on, value: @account_close["effective_on"], class: "mt-1 w-full rounded border border-slate-300 px-3 py-2" %>
      </div>
      <div>
        <%= form.label :reason_code, class: "block text-sm font-medium text-slate-700" %>
        <%= form.text_field :reason_code, value: @account_close["reason_code"], required: true, class: "mt-1 w-full rounded border border-slate-300 px-3 py-2" %>
      </div>
      <div class="md:col-span-2">
        <%= form.label :reason_description, class: "block text-sm font-medium text-slate-700" %>
        <%= form.text_area :reason_description, value: @account_close["reason_description"], rows: 3, class: "mt-1 w-full rounded border border-slate-300 px-3 py-2" %>
      </div>
      <div class="md:col-span-2">
        <%= form.label :idempotency_key, class: "block text-sm font-medium text-slate-700" %>
        <%= form.text_field :idempotency_key, value: @account_close["idempotency_key"], required: true, class: "mt-1 w-full rounded border border-slate-300 px-3 py-2" %>
      </div>
    </div>

    <div class="mt-6 flex gap-3">
      <%= form.submit "Close account", class: "rounded bg-red-700 px-4 py-2 font-medium text-white" %>
      <%= link_to "Cancel", branch_servicing_deposit_account_path(@account), class: "rounded border border-slate-300 px-4 py-2 font-medium text-slate-700" %>
    </div>
  <% end %>
</section>
