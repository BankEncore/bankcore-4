<% content_for :title, "Customer Servicing - BankCORE" %>

<section class="flex flex-col justify-between gap-4 md:flex-row md:items-end">
  <div>
    <h1 class="text-3xl font-semibold">Customer servicing</h1>
    <p class="mt-2 text-slate-600">Search by party id, legal name, or individual profile names.</p>
  </div>
  <%= link_to "Back to Branch", branch_path, class: "rounded border border-slate-300 px-4 py-2 font-medium text-slate-700" %>
</section>

<section class="mt-6 rounded border border-slate-200 bg-white p-5 shadow-sm">
  <%= form_with url: branch_customers_path, method: :get, class: "grid gap-4 md:grid-cols-[1fr_auto]" do |form| %>
    <div>
      <%= form.label :query, "Customer search", class: "block text-sm font-medium text-slate-700" %>
      <%= form.text_field :query, value: @query, placeholder: "Party id or customer name", class: "mt-1 w-full rounded border border-slate-300 px-3 py-2" %>
    </div>
    <div class="self-end">
      <%= form.submit "Search", class: "rounded bg-slate-900 px-4 py-2 font-medium text-white" %>
    </div>
  <% end %>
</section>

<section class="mt-6 overflow-hidden rounded border border-slate-200 bg-white shadow-sm">
  <% if @search.nil? %>
    <div class="p-6 text-sm text-slate-600">Enter a party id or name to begin customer servicing.</div>
  <% elsif @search.rows.any? %>
    <table class="min-w-full divide-y divide-slate-200 text-sm">
      <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
        <tr>
          <th class="px-5 py-3">Customer</th>
          <th class="px-5 py-3">Type</th>
          <th class="px-5 py-3">Profile</th>
          <th class="px-5 py-3">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @search.rows.each do |party| %>
          <tr>
            <td class="px-5 py-4">
              <div class="font-medium text-slate-950"><%= party.name %></div>
              <div class="text-xs text-slate-500">Party #<%= party.id %></div>
            </td>
            <td class="px-5 py-4"><%= party.party_type %></td>
            <td class="px-5 py-4">
              <% if party.individual_profile %>
                <%= [party.individual_profile.first_name, party.individual_profile.last_name].compact.join(" ") %>
              <% else %>
                Not recorded
              <% end %>
            </td>
            <td class="px-5 py-4">
              <%= link_to "Open 360", branch_customer_path(party), class: "rounded bg-slate-900 px-3 py-1.5 font-medium text-white" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="p-6 text-sm text-slate-600">No customers found for “<%= @search.query %>”.</div>
  <% end %>
</section>
