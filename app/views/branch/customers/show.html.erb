<% content_for :title, "#{@party.name} - BankCORE" %>

<section class="flex flex-col justify-between gap-4 md:flex-row md:items-end">
  <div>
    <h1 class="text-3xl font-semibold"><%= @party.name %></h1>
    <p class="mt-2 text-slate-600">Customer 360 for party #<%= @party.id %>.</p>
  </div>
  <nav class="flex flex-wrap gap-2 text-sm">
    <%= link_to "Back to search", branch_customers_path, class: "rounded border border-slate-300 px-4 py-2 font-medium text-slate-700" %>
    <%= link_to "Open account", new_branch_deposit_account_path(party_record_id: @party.id), class: "rounded bg-slate-900 px-4 py-2 font-medium text-white" %>
  </nav>
</section>

<section class="mt-6 grid gap-4 md:grid-cols-3">
  <div class="rounded border border-slate-200 bg-white p-5 shadow-sm">
    <p class="text-sm font-medium text-slate-500">Party type</p>
    <p class="mt-2 text-2xl font-semibold"><%= @party.party_type %></p>
  </div>
  <div class="rounded border border-slate-200 bg-white p-5 shadow-sm">
    <p class="text-sm font-medium text-slate-500">Party id</p>
    <p class="mt-2 text-2xl font-semibold">#<%= @party.id %></p>
  </div>
  <div class="rounded border border-slate-200 bg-white p-5 shadow-sm">
    <p class="text-sm font-medium text-slate-500">Linked accounts</p>
    <p class="mt-2 text-2xl font-semibold"><%= @account_relationships.size %></p>
  </div>
</section>

<% if @party.individual_profile %>
  <% profile = @party.individual_profile %>
  <section class="mt-6 rounded border border-slate-200 bg-white p-6 shadow-sm">
    <h2 class="text-xl font-semibold">Individual profile</h2>
    <dl class="mt-4 grid gap-4 text-sm md:grid-cols-2">
      <div><dt class="font-medium text-slate-500">Legal name</dt><dd><%= [profile.first_name, profile.middle_name, profile.last_name, profile.name_suffix].compact.join(" ") %></dd></div>
      <div><dt class="font-medium text-slate-500">Preferred name</dt><dd><%= [profile.preferred_first_name, profile.preferred_last_name].compact.join(" ").presence || "Not recorded" %></dd></div>
      <div><dt class="font-medium text-slate-500">Date of birth</dt><dd><%= branch_date(profile.date_of_birth) %></dd></div>
      <div><dt class="font-medium text-slate-500">Occupation</dt><dd><%= profile.occupation.presence || "Not recorded" %></dd></div>
      <div><dt class="font-medium text-slate-500">Employer</dt><dd><%= profile.employer.presence || "Not recorded" %></dd></div>
    </dl>
  </section>
<% end %>

<section class="mt-6 overflow-hidden rounded border border-slate-200 bg-white shadow-sm">
  <div class="border-b border-slate-200 px-5 py-4">
    <h2 class="text-xl font-semibold">Linked deposit accounts</h2>
  </div>
  <% if @account_relationships.any? %>
    <table class="min-w-full divide-y divide-slate-200 text-sm">
      <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
        <tr>
          <th class="px-5 py-3">Account</th>
          <th class="px-5 py-3">Product</th>
          <th class="px-5 py-3">Relationship</th>
          <th class="px-5 py-3">Effective</th>
          <th class="px-5 py-3">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @account_relationships.each do |row| %>
          <tr>
            <td class="px-5 py-4">
              <div class="font-medium text-slate-950"><%= row.account.account_number %></div>
              <div class="text-xs text-slate-500"><%= row.account.status %> · <%= row.account.currency %></div>
            </td>
            <td class="px-5 py-4">
              <div><%= row.product.product_code %></div>
              <div class="text-xs text-slate-500"><%= row.product.name %></div>
            </td>
            <td class="px-5 py-4"><%= row.relationship.role %> · <%= row.relationship.status %></td>
            <td class="px-5 py-4"><%= branch_date(row.relationship.effective_on) %></td>
            <td class="px-5 py-4">
              <%= link_to "Service account", branch_servicing_deposit_account_path(row.account), class: "rounded bg-slate-900 px-3 py-1.5 font-medium text-white" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="p-6 text-sm text-slate-600">No linked deposit accounts.</div>
  <% end %>
</section>
