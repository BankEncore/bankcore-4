<% content_for :title, "Create Party - BankCORE" %>

<section>
  <h1 class="text-3xl font-semibold">Create individual party</h1>
  <p class="mt-2 text-slate-600">Create the party record used to open a deposit account.</p>
</section>

<%= render "branch/shared/form_error", error_message: @error_message %>

<section class="mt-6 rounded border border-slate-200 bg-white p-6 shadow-sm">
  <%= form_with url: branch_parties_path, scope: :party, method: :post, class: "grid gap-4 md:grid-cols-2" do |form| %>
    <%= form.hidden_field :party_type, value: @party["party_type"] || "individual" %>
    <div>
      <%= form.label :first_name, class: "block text-sm font-medium text-slate-700" %>
      <%= form.text_field :first_name, value: @party["first_name"], class: "mt-1 w-full rounded border border-slate-300 px-3 py-2" %>
    </div>
    <div>
      <%= form.label :middle_name, class: "block text-sm font-medium text-slate-700" %>
      <%= form.text_field :middle_name, value: @party["middle_name"], class: "mt-1 w-full rounded border border-slate-300 px-3 py-2" %>
    </div>
    <div>
      <%= form.label :last_name, class: "block text-sm font-medium text-slate-700" %>
      <%= form.text_field :last_name, value: @party["last_name"], class: "mt-1 w-full rounded border border-slate-300 px-3 py-2" %>
    </div>
    <div>
      <%= form.label :name_suffix, class: "block text-sm font-medium text-slate-700" %>
      <%= form.text_field :name_suffix, value: @party["name_suffix"], class: "mt-1 w-full rounded border border-slate-300 px-3 py-2" %>
    </div>
    <div class="md:col-span-2">
      <%= form.submit "Create party", class: "rounded bg-slate-900 px-4 py-2 font-medium text-white" %>
    </div>
  <% end %>
</section>
