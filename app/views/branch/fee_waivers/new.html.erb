<% content_for :title, "Fee Waiver - BankCORE" %>

<section>
  <h1 class="text-3xl font-semibold">Waive fee</h1>
  <p class="mt-2 text-slate-600">Account <%= @account.account_number %></p>
</section>

<%= render "branch/shared/form_error", error_message: @error_message %>
<%= render "branch/shared/transaction_preview", preview: @preview if @preview.present? %>

<section class="mt-6 rounded border border-slate-200 bg-white p-6 shadow-sm">
  <% if @fee_event %>
    <h2 class="text-xl font-semibold">Fee assessment #<%= @fee_event.id %></h2>
    <dl class="mt-4 grid gap-4 text-sm md:grid-cols-2">
      <div><dt class="font-medium text-slate-500">Amount</dt><dd><%= branch_money(@fee_event.amount_minor_units) %> <%= @fee_event.currency %></dd></div>
      <div><dt class="font-medium text-slate-500">Business date</dt><dd><%= branch_date(@fee_event.business_date) %></dd></div>
      <div><dt class="font-medium text-slate-500">Channel</dt><dd><%= @fee_event.channel %></dd></div>
      <div><dt class="font-medium text-slate-500">Reference</dt><dd><%= @fee_event.reference_id.presence || "None" %></dd></div>
    </dl>
  <% else %>
    <p class="text-sm text-slate-600">Enter the posted fee assessment event to waive.</p>
  <% end %>

  <%= form_with url: branch_fee_waivers_path(@account), scope: :fee_waiver, class: "mt-6 grid gap-4 md:grid-cols-2" do |form| %>
    <div>
      <%= form.label :fee_assessment_event_id, "Fee assessment event id", class: "block text-sm font-medium text-slate-700" %>
      <%= form.text_field :fee_assessment_event_id, value: @fee_waiver["fee_assessment_event_id"] || @fee_waiver[:fee_assessment_event_id], class: "mt-1 w-full rounded border border-slate-300 px-3 py-2" %>
    </div>
    <div>
      <%= form.label :idempotency_key, class: "block text-sm font-medium text-slate-700" %>
      <%= form.text_field :idempotency_key, value: @fee_waiver["idempotency_key"] || @fee_waiver[:idempotency_key], class: "mt-1 w-full rounded border border-slate-300 px-3 py-2" %>
    </div>
    <div class="flex items-center gap-2">
      <%= form.check_box :record_and_post, { checked: ActiveModel::Type::Boolean.new.cast(@fee_waiver["record_and_post"] || @fee_waiver[:record_and_post]) }, "1", "0" %>
      <%= form.label :record_and_post, "Record and post immediately", class: "text-sm font-medium text-slate-700" %>
    </div>
    <div class="self-end">
      <%= form.submit "Waive fee", class: "rounded bg-slate-900 px-4 py-2 font-medium text-white" %>
    </div>
  <% end %>
</section>
